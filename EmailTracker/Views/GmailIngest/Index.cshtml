@{
    ViewData["Title"] = "Gmail Ingest";
}

<div class="row g-3">
    <div class="col-12 col-lg-8">
        <div class="table-card p-4">

            <h5 class="fw-semibold mb-1"><i class="fas fa-download me-2 text-primary"></i>Run Gmail Ingest</h5>
            <p class="text-muted mb-4" style="font-size:.875rem">
                Extracts Gmail headers and loads them into the database.
                Existing senders keep their ratings. Duplicate messages are skipped automatically.
            </p>

            <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#ingestModal">
                <i class="fas fa-play me-2"></i>Start Ingest
            </button>

        </div>
    </div>
</div>

<!-- Toast — shown when job completes while modal is hidden -->
<div class="toast-container position-fixed top-0 end-0 p-3" style="z-index:9999">
    <div id="ingest-toast" class="toast align-items-center border-0" role="alert" aria-live="assertive">
        <div class="d-flex">
            <div class="toast-body fw-semibold" id="toast-msg"></div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<!-- Ingest Modal -->
<div class="modal fade" id="ingestModal" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title fw-semibold"><i class="fas fa-download me-2 text-primary"></i>Gmail Ingest</h5>
                <button type="button" class="btn-close" id="btn-modal-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">

                <form id="ingest-form">
                    @Html.AntiForgeryToken()

                    <div class="mb-4">
                        <label class="form-label fw-semibold" style="font-size:.875rem">
                            Harvest window: <span id="days-label" class="text-primary">14 days</span>
                        </label>
                        <input id="days-slider" name="days" type="range"
                               class="form-range" min="1" max="14" step="1" value="14" />
                        <div class="d-flex justify-content-between text-muted" style="font-size:.75rem;margin-top:2px">
                            <span>1 day</span>
                            <span>14 days</span>
                        </div>
                    </div>

                    <table class="table table-sm mb-4" style="font-size:.8rem">
                        <tr><td class="text-muted">Query</td><td><code id="query-label">newer_than:14d</code></td></tr>
                        <tr><td class="text-muted">Max messages</td><td><code>4000</code></td></tr>
                        <tr><td class="text-muted">Database</td><td><code>gmailanalysis.db</code></td></tr>
                    </table>

                    <!-- Progress panel (shown while running) -->
                    <div id="progress-panel" style="display:none">
                        <hr class="my-3" />
                        <div class="d-flex align-items-center gap-3">
                            <div class="spinner-border spinner-border-sm text-primary flex-shrink-0"></div>
                            <div>
                                <div class="fw-semibold" style="font-size:.875rem">Ingest running&hellip;</div>
                                <div id="step-label" class="text-muted" style="font-size:.8rem">Starting&hellip;</div>
                                <div class="text-muted" style="font-size:.8rem">
                                    Elapsed: <span id="elapsed">0s</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Result panel (shown when complete or failed) -->
                    <div id="result-panel" style="display:none">
                        <hr class="my-3" />
                        <div id="result-content"></div>
                    </div>

                </form>

            </div>

            <div class="modal-footer" id="modal-footer">
                <button type="button" class="btn btn-secondary" id="btn-cancel" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-outline-secondary" id="btn-hide" style="display:none"
                        onclick="hideAndBackground()">
                    <i class="fas fa-minus me-1"></i>Hide
                </button>
                <button id="btn-start" type="submit" form="ingest-form" class="btn btn-primary">
                    <i class="fas fa-play me-2"></i>Start Ingest
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
<script>
// Slider — live label update
$('#days-slider').on('input', function () {
    var d = $(this).val();
    $('#days-label').text(d == 1 ? '1 day' : d + ' days');
    $('#query-label').text('newer_than:' + d + 'd');
});

// Reset modal state when closed
$('#ingestModal').on('hidden.bs.modal', function () {
    if (!_backgroundMode) resetModal();
});

function resetModal() {
    _backgroundMode = false;
    $('#days-slider').val(14);
    $('#days-label').text('14 days');
    $('#query-label').text('newer_than:14d');
    $('#progress-panel').hide();
    $('#result-panel').hide();
    $('#result-content').html('');
    $('#step-label').text('Starting\u2026');
    $('#btn-start').show().prop('disabled', false).html('<i class="fas fa-play me-2"></i>Start Ingest');
    $('#btn-cancel').show().text('Cancel');
    $('#btn-hide').hide();
    stopElapsed();
}

var _pollTimer      = null;
var _elapsedSec     = 0;
var _elapsedTimer   = null;
var _backgroundMode = false;

function startElapsed() {
    _elapsedSec = 0;
    clearInterval(_elapsedTimer);
    _elapsedTimer = setInterval(function () {
        _elapsedSec++;
        var m = Math.floor(_elapsedSec / 60);
        var s = _elapsedSec % 60;
        $('#elapsed').text(m > 0 ? m + 'm ' + s + 's' : s + 's');
    }, 1000);
}

function stopElapsed() { clearInterval(_elapsedTimer); }

function hideAndBackground() {
    _backgroundMode = true;
    bootstrap.Modal.getInstance(document.getElementById('ingestModal')).hide();
}

function showToast(msg, success) {
    var $toast = $('#ingest-toast');
    $toast.removeClass('text-bg-success text-bg-danger')
          .addClass(success ? 'text-bg-success' : 'text-bg-danger');
    $('#toast-msg').text(msg);
    var t = bootstrap.Toast.getOrCreateInstance($toast[0], { delay: 6000 });
    t.show();
}

function finishPoll(r) {
    stopElapsed();
    clearTimeout(_pollTimer);
    $('#progress-panel').hide();
    $('#btn-hide').hide();
    $('#btn-start').hide();
    $('#btn-cancel').show().text('Close');

    if (_backgroundMode) {
        if (r.status === 'complete' && r.result) {
            showToast('Ingest complete \u2714  ' + r.result.messagesLoaded + ' messages loaded', true);
        } else {
            showToast('Ingest failed \u2014 open Gmail Ingest for details', false);
            // Re-open modal to show the error
            _backgroundMode = false;
            buildResultHtml(r);
            $('#result-panel').show();
            bootstrap.Modal.getOrCreateInstance(document.getElementById('ingestModal')).show();
        }
        return;
    }

    buildResultHtml(r);
    $('#result-panel').show();
}

function buildResultHtml(r) {
    var html;
    if (r.status === 'complete' && r.result) {
        var res = r.result;
        html =
            '<div class="alert alert-success mb-0">' +
            '  <strong>Ingest complete.</strong>' +
            '  <table class="table table-sm mt-3 mb-2" style="font-size:.875rem">' +
            '    <tr><td>Run ID</td><td><strong>#' + res.runId + '</strong></td></tr>' +
            '    <tr><td>Messages loaded</td><td><strong>' + res.messagesLoaded + '</strong></td></tr>' +
            '    <tr><td>New senders</td><td><strong>' + res.newSenders + '</strong></td></tr>' +
            '    <tr><td>Updated senders</td><td><strong>' + res.updatedSenders + '</strong></td></tr>' +
            '    <tr><td>Duplicates skipped</td><td><strong>' + res.skippedDuplicates + '</strong></td></tr>' +
            '    <tr><td>Completed at</td><td class="text-muted">' + res.completedAt + '</td></tr>' +
            '    <tr><td>Source file</td><td class="text-muted" style="font-size:.75rem;word-break:break-all">' + res.sourceFile + '</td></tr>' +
            '  </table>' +
            '  <a href="/Run" class="btn btn-sm btn-outline-success">View Runs</a>' +
            '  <a href="/Sender" class="btn btn-sm btn-outline-secondary ms-2">View Senders</a>' +
            '</div>';
    } else if (r.status === 'not_found') {
        html =
            '<div class="alert alert-warning mb-0">' +
            '  <strong>Job not found.</strong> The server may have restarted while the ingest was running.' +
            '</div>';
    } else {
        html =
            '<div class="alert alert-danger mb-0">' +
            '  <strong>Ingest failed.</strong>' +
            '  <pre class="mt-2 mb-0" style="font-size:.8rem;white-space:pre-wrap">' + (r.error || 'Unknown error') + '</pre>' +
            '</div>';
    }
    $('#result-content').html(html);
}

function pollStatus(jobId) {
    $.getJSON('/GmailIngest/Status/' + jobId, function (r) {
        if (r.status === 'running' || r.status === 'queued') {
            if (r.step) $('#step-label').text(r.step);
            _pollTimer = setTimeout(function () { pollStatus(jobId); }, 3000);
            return;
        }
        finishPoll(r);
    }).fail(function () {
        finishPoll({ status: 'failed', error: 'Status request failed \u2014 check server logs.' });
    });
}

$('#ingest-form').on('submit', function (e) {
    e.preventDefault();

    _backgroundMode = false;
    $('#result-panel').hide();
    $('#btn-start').prop('disabled', true).html('<i class="fas fa-stop-circle me-2"></i>Running\u2026');
    $('#btn-cancel').hide();
    $('#btn-hide').show();
    $('#step-label').text('Starting\u2026');
    $('#progress-panel').show();
    startElapsed();

    $.ajax({
        url:  '/GmailIngest/Start',
        type: 'POST',
        data: $(this).serialize(),
        success: function (r) {
            if (!r || !r.jobId) {
                stopElapsed();
                $('#progress-panel').hide();
                $('#btn-hide').hide();
                $('#result-content').html('<div class="alert alert-danger mb-0">Server did not return a job ID \u2014 check server logs.</div>');
                $('#result-panel').show();
                $('#btn-start').hide();
                $('#btn-cancel').show().text('Close');
                return;
            }
            pollStatus(r.jobId);
        },
        error: function () {
            stopElapsed();
            $('#progress-panel').hide();
            $('#btn-hide').hide();
            $('#result-content').html('<div class="alert alert-danger mb-0">Failed to start ingest \u2014 check server logs.</div>');
            $('#result-panel').show();
            $('#btn-start').hide();
            $('#btn-cancel').show().text('Close');
        }
    });
});
</script>
}
