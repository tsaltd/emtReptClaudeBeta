@model DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }

@section Styles {
<style>
    /* ── Stat cards ───────────────────────────────────────────────── */
    .hub-stat {
        background: #fff; border: 1px solid #dee2e6;
        border-radius: 6px; padding: .9rem 1.25rem;
        display: flex; align-items: center; gap: 1rem;
    }
    .hub-stat-icon { font-size: 1.5rem; width: 2rem; text-align: center; color: #495057; }
    .hub-stat-val  { font-size: 1.6rem; font-weight: 700; line-height: 1; color: #212529; }
    .hub-stat-lbl  { font-size: .72rem; text-transform: uppercase; letter-spacing: .5px; color: #444; margin-top: .15rem; }

    /* ── Hub panel ────────────────────────────────────────────────── */
    .hub-panel {
        background: #fff; border: 1px solid #dee2e6;
        border-radius: 6px; overflow: hidden;
    }
    .hub-panel-header {
        background: #f8f9fa; border-bottom: 1px solid #dee2e6;
        padding: .55rem 1rem;
        font-size: .68rem; font-weight: 700; text-transform: uppercase;
        letter-spacing: .6px; color: #333;
    }
    .hub-panel-body { padding: 1rem; }

    /* ── Launch buttons ───────────────────────────────────────────── */
    .hub-launch-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
        gap: .6rem;
    }
    .hub-btn {
        display: flex; flex-direction: column; align-items: flex-start;
        gap: .2rem; padding: .65rem .9rem;
        border: 1px solid #dee2e6; border-radius: 5px;
        background: #f8f9fa; cursor: pointer;
        text-decoration: none; transition: all .12s;
        color: #212529;
    }
    .hub-btn:hover { background: #e7efff; border-color: #0d6efd; color: #0d6efd; }
    .hub-btn i     { font-size: .95rem; }
    .hub-btn-label { font-size: .8rem; font-weight: 600; }
    .hub-btn-sub   { font-size: .68rem; color: #555; }
    .hub-btn:hover .hub-btn-sub { color: #6ea8fe; }
</style>
}

<!-- Stat strip -->
<div class="row g-2 mb-3">
    <div class="col-sm-4">
        <div class="hub-stat">
            <div class="hub-stat-icon"><i class="fas fa-layer-group"></i></div>
            <div>
                <div class="hub-stat-val">@Model.TotalRuns</div>
                <div class="hub-stat-lbl">Runs</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="hub-stat">
            <div class="hub-stat-icon"><i class="fas fa-envelope"></i></div>
            <div>
                <div class="hub-stat-val" id="stat-messages">@Model.TotalMessages.ToString("N0")</div>
                <div class="hub-stat-lbl">Messages</div>
            </div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="hub-stat">
            <div class="hub-stat-icon"><i class="fas fa-users"></i></div>
            <div>
                <div class="hub-stat-val" id="stat-senders">@Model.TotalSenders.ToString("N0")</div>
                <div class="hub-stat-lbl">Senders</div>
            </div>
        </div>
    </div>
</div>

@if (Model.MostRecentRun != null)
{
    <div class="alert alert-info py-2 px-3 d-flex align-items-center gap-3 mb-3" style="font-size:.82rem">
        <i class="fas fa-clock"></i>
        <span>
            <strong>Last run:</strong> @Model.MostRecentRun.DisplayWindow &nbsp;·&nbsp;
            <span class="badge bg-primary">@Model.MostRecentRun.MessageCount msg</span>
            <span class="badge bg-secondary ms-1">@Model.MostRecentRun.SenderCount senders</span>
        </span>
        <a asp-controller="Run" asp-action="Detail" asp-route-id="@Model.MostRecentRun.RunId"
           class="btn btn-sm btn-outline-primary ms-auto" style="font-size:.75rem">View Run →</a>
    </div>
}

<div class="row g-3">
    <!-- Left: criteria panel -->
    <div class="col-lg-5">
        <div class="hub-panel h-100">
            <div class="hub-panel-header">Selection Criteria</div>
            <div class="hub-panel-body">
                <!-- Search -->
                <div class="mb-3">
                    <label class="form-label small fw-semibold mb-1" style="font-size:.68rem;text-transform:uppercase;letter-spacing:.5px">Search</label>
                    <input id="hub-search" type="text" class="form-control form-control-sm"
                           placeholder="Email, subject, snippet…" style="border-radius:0" />
                </div>

                <!-- Filter bar (date / status / rating / priority) -->
                @await Html.PartialAsync("_FilterBar", new FilterBarViewModel
                {
                    AvailableRatings = Model.RatingBreakdown
                })

                <div class="mt-2 d-flex justify-content-end">
                    <button type="button" id="hub-reset" class="btn btn-sm btn-outline-secondary" style="border-radius:0;font-size:.75rem">
                        ✕ Reset All
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: launch grid -->
    <div class="col-lg-7">
        <div class="hub-panel">
            <div class="hub-panel-header">Launch View</div>
            <div class="hub-panel-body">

                <p class="text-muted small mb-3">Set criteria on the left, then click any view to open it pre-filtered.</p>

                <!-- Senders -->
                <div class="mb-1" style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#333">Senders</div>
                <div class="hub-launch-grid mb-3">
                    <button class="hub-btn" onclick="launch('/Sender/Index')">
                        <i class="fas fa-users"></i>
                        <span class="hub-btn-label">Sender List</span>
                        <span class="hub-btn-sub">search · rating · status</span>
                    </button>
                    <button class="hub-btn" onclick="launch('/Sender/QuickRate')">
                        <i class="fas fa-star-half-alt"></i>
                        <span class="hub-btn-label">Quick Rate</span>
                        <span class="hub-btn-sub">bulk rating · search · status</span>
                    </button>
                    <button class="hub-btn" onclick="launch('/Sender/Browse', false)">
                        <i class="fas fa-address-card"></i>
                        <span class="hub-btn-label">Browse Senders</span>
                        <span class="hub-btn-sub">single-record navigator</span>
                    </button>
                </div>

                <!-- Messages -->
                <div class="mb-1" style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#333">Messages</div>
                <div class="hub-launch-grid mb-3">
                    <button class="hub-btn" onclick="launch('/Message/CeaReports')">
                        <i class="fas fa-file-alt"></i>
                        <span class="hub-btn-label">CEA Reports</span>
                        <span class="hub-btn-sub">tree · date · status · rating</span>
                    </button>
                    <button class="hub-btn" onclick="launch('/Message/Grouped')">
                        <i class="fas fa-layer-group"></i>
                        <span class="hub-btn-label">CEA Groups</span>
                        <span class="hub-btn-sub">grouped · pills · priority</span>
                    </button>
                    <button class="hub-btn" onclick="launch('/Message/Index')">
                        <i class="fas fa-envelope"></i>
                        <span class="hub-btn-label">Messages</span>
                        <span class="hub-btn-sub">flat list · search · date</span>
                    </button>
                    <button class="hub-btn" onclick="launch('/Message/Browse', false)">
                        <i class="fas fa-address-card"></i>
                        <span class="hub-btn-label">Msg Browse</span>
                        <span class="hub-btn-sub">sender panel · message list</span>
                    </button>
                </div>

                <!-- Tools -->
                <div class="mb-1" style="font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#333">Tools</div>
                <div class="hub-launch-grid">
                    <button class="hub-btn" onclick="window.location='/GmailIngest'">
                        <i class="fas fa-download"></i>
                        <span class="hub-btn-label">Gmail Ingest</span>
                        <span class="hub-btn-sub">run harvester</span>
                    </button>
                    <button class="hub-btn" onclick="window.location='/Run'">
                        <i class="fas fa-layer-group"></i>
                        <span class="hub-btn-label">Runs</span>
                        <span class="hub-btn-sub">ingest history</span>
                    </button>
                </div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function launch(url, useFilters) {
    if (useFilters === false) {
        window.location = url;
        return;
    }
    var f      = FilterBar.getValues();
    var search = $('#hub-search').val().trim();
    var params = {};

    if (search)           params.searchTerm   = search;
    if (f.ratingFilter)   params.ratingFilter  = f.ratingFilter;
    if (f.statusFilter)   params.statusFilter  = f.statusFilter;
    if (f.dateFrom)       params.dateFrom      = f.dateFrom;
    if (f.dateTo)         params.dateTo        = f.dateTo;
    if (f.priorityOnly)   params.priorityOnly  = 'true';

    var qs = $.param(params);
    window.location = url + (qs ? '?' + qs : '');
}

$('#hub-reset').on('click', function () {
    $('#hub-search').val('');
    document.getElementById('fb-clear').click();
});

function refreshStats() {
    var f = FilterBar.getValues();
    var params = $.param({
        ratingFilter: f.ratingFilter,
        statusFilter: f.statusFilter,
        dateFrom:     f.dateFrom,
        dateTo:       f.dateTo
    });
    $.getJSON('/Home/FilteredStats?' + params, function(r) {
        if (r.messages !== null) $('#stat-messages').text(Number(r.messages).toLocaleString());
        $('#stat-senders').text(Number(r.senders).toLocaleString());
    });
}

FilterBar.onChange = function() { refreshStats(); };

// Apply stored filter on initial load
(function() {
    var f = FilterBar.getValues();
    if (f.ratingFilter || f.statusFilter || f.dateFrom || f.dateTo) {
        refreshStats();
    }
})();
</script>
}
