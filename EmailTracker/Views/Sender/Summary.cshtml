@model SenderSummaryPageViewModel
@{ ViewData["Title"] = "Sender Summary"; }

@Html.AntiForgeryToken()

@* ── Nav + Prev/Next ─────────────────────────────────────────── *@
<div class="d-flex align-items-center gap-2 mb-3 flex-wrap">
    <a asp-controller="Sender" asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-arrow-left me-1"></i> Senders
    </a>
    <a asp-controller="Sender" asp-action="Detail" asp-route-id="@Model.SenderId"
       class="btn btn-sm btn-outline-secondary ms-1">Detail</a>
    <a asp-controller="Message" asp-action="Index" asp-route-senderId="@Model.SenderId"
       class="btn btn-sm btn-outline-primary ms-auto">
        <i class="fas fa-envelope me-1"></i> All Messages
    </a>

    <span class="vr"></span>
    <a href="?id=@Model.SenderId&page=1&pageSize=@Model.PageSize&sortAsc=@((!Model.SortAsc).ToString().ToLower())"
       class="btn btn-sm btn-outline-secondary">
        <i class="fas fa-sort-amount-@(Model.SortAsc ? "up" : "down") me-1"></i>@(Model.SortAsc ? "Asc" : "Desc")
    </a>

    @if (Model.TotalPages > 1)
    {
        <span class="vr"></span>
        <a href="?id=@Model.SenderId&page=@Model.PrevPage&pageSize=@Model.PageSize&sortAsc=@(Model.SortAsc.ToString().ToLower())"
           class="btn btn-sm btn-outline-secondary @(!Model.HasPrev ? "disabled" : "")">
            <i class="fas fa-chevron-left"></i> Prev
        </a>
        <span class="small">@Model.Page / @Model.TotalPages</span>
        <a href="?id=@Model.SenderId&page=@Model.NextPage&pageSize=@Model.PageSize&sortAsc=@(Model.SortAsc.ToString().ToLower())"
           class="btn btn-sm btn-outline-secondary @(!Model.HasNext ? "disabled" : "")">
            Next <i class="fas fa-chevron-right"></i>
        </a>
    }
</div>

@* ── Condensed sender header ─────────────────────────────────── *@
<div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-3 d-flex align-items-center gap-3 flex-wrap">
        <code class="fw-bold">@Model.EmailAddress</code>
        @if (!string.IsNullOrEmpty(Model.DisplayName))
        {
            <span class="vr d-none d-md-block"></span>
            <span class="small">@Model.DisplayName</span>
        }
        <span class="vr d-none d-md-block"></span>
        <span class="badge bg-primary rounded-pill">@Model.MsgCount.ToString("N0") msgs</span>
        @if (!string.IsNullOrEmpty(Model.FirstSeen))
        {
            var fs = DateTime.TryParse(Model.FirstSeen, out var fsDt) ? fsDt.ToString("MMM d, yyyy") : Model.FirstSeen;
            var ls = DateTime.TryParse(Model.LastSeen,  out var lsDt) ? lsDt.ToString("MMM d, yyyy") : Model.LastSeen;
            <span class="small">@fs – @ls</span>
        }
        <span class="ms-auto">
            <div class="rating-picker" data-mode="row" data-sender-id="@Model.SenderId">
                <button type="button" class="rating-picker-btn has-color"
                        style="background:@Model.ColorCode" title="@Model.RatingName"></button>
                <div class="rating-picker-panel">
                    @foreach (var r in Model.AvailableRatings)
                    {
                        <div class="rating-swatch @(r.RatingId == Model.RatingId ? "active" : "")"
                             style="background:@r.ColorCode"
                             data-rating-id="@r.RatingId"
                             data-rating-name="@r.RatingName"
                             data-color="@r.ColorCode"
                             title="@r.RatingName"></div>
                    }
                </div>
            </div>
        </span>
    </div>
</div>

@* ── From_raw groups ─────────────────────────────────────────── *@
@if (!Model.FromRawGroups.Any())
{
    <p class="text-muted text-center py-4">No messages found for this sender.</p>
}
else
{
    int groupIndex = 0;
    foreach (var group in Model.FromRawGroups)
    {
        var collapseId = $"raw-group-{groupIndex++}";
        <div class="card border-0 shadow-sm mb-2">
            <div class="card-header bg-white d-flex align-items-center gap-2 py-2 px-3"
                 style="cursor:pointer" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                <span class="flex-grow-1 fw-semibold" style="word-break:break-all; font-size:.9rem; font-family:'Segoe UI',sans-serif; color:#212529;">@group.FromRaw</span>
                <span class="badge bg-primary rounded-pill flex-shrink-0">@group.Messages.Count</span>
                <i class="fas fa-chevron-down text-muted small flex-shrink-0"></i>
            </div>
            <div id="@collapseId" class="collapse show">
                <div class="table-responsive">
                    <table class="table table-hover table-sm mb-0" style="font-size:.8rem">
                        <thead class="table-light">
                            <tr>
                                <th style="width:28px"></th>
                                <th style="width:140px">Date</th>
                                <th>Subject</th>
                                <th>Snippet</th>
                                <th style="width:55px">Run</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in group.Messages)
                            {
                                <tr>
                                    <td>
                                        <button type="button"
                                                class="star-btn @(m.IsPriority ? "starred" : "")"
                                                data-gmail-id="@m.GmailMessageId"
                                                title="@(m.IsPriority ? "Remove priority" : "Mark priority")">★</button>
                                    </td>
                                    <td class="text-nowrap">@m.DisplayDate</td>
                                    <td>@(m.Subject ?? "—")</td>
                                    <td class="" style="max-width:320px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@(m.Snippet ?? "")</td>
                                    <td class="">
                                        <a asp-controller="Run" asp-action="Detail" asp-route-id="@m.RunId"
                                           class="text-decoration-none">#@m.RunId</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}

@* ── Pagination footer ───────────────────────────────────────── *@
@if (Model.TotalPages > 1)
{
    <div class="card border-0 shadow-sm mt-3">
        <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between">
            <a href="?id=@Model.SenderId&page=@Model.PrevPage&pageSize=@Model.PageSize&sortAsc=@(Model.SortAsc.ToString().ToLower())"
               class="btn btn-sm btn-outline-secondary @(!Model.HasPrev ? "disabled" : "")">
                <i class="fas fa-chevron-left me-1"></i> Prev
            </a>
            <span class="small">
                Page @Model.Page of @Model.TotalPages
                <span class="ms-2">(@Model.TotalGroups from-names total)</span>
            </span>
            <a href="?id=@Model.SenderId&page=@Model.NextPage&pageSize=@Model.PageSize&sortAsc=@(Model.SortAsc.ToString().ToLower())"
               class="btn btn-sm btn-outline-secondary @(!Model.HasNext ? "disabled" : "")">
                Next <i class="fas fa-chevron-right ms-1"></i>
            </a>
        </div>
    </div>
}

@* ── Toast ────────────────────────────────────────────────────── *@
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div id="rating-toast" class="toast align-items-center border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toast-msg">Rating saved.</div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

@section Styles {
<style>
    .star-btn {
        background: none; border: none; cursor: pointer;
        font-size: 1rem; line-height: 1; padding: 0;
        color: #ccc; transition: color .15s;
    }
    .star-btn:hover   { color: #f0a500; }
    .star-btn.starred { color: #f0a500; }
</style>
}

@section Scripts {
<script>
(function () {
    var toast = new bootstrap.Toast(document.getElementById('rating-toast'), { delay: 2000 });
    var token = $('input[name="__RequestVerificationToken"]').val();

    // Star / priority toggle
    $(document).on('click', '.star-btn', function () {
        var $btn = $(this);
        var gmailId = $btn.data('gmail-id');
        $.ajax({
            url: '/Message/TogglePriority', method: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': token },
            data: JSON.stringify(gmailId),
            success: function (res) {
                $btn.toggleClass('starred', res.isPriority)
                    .attr('title', res.isPriority ? 'Remove priority' : 'Mark priority');
            }
        });
    });

    $(document).on('click', '.rating-picker[data-mode="row"] .rating-swatch', function (e) {
        e.stopPropagation();
        var ratingId   = $(this).data('rating-id');
        var ratingName = $(this).data('rating-name');
        var color      = $(this).data('color');
        var $picker    = $(this).closest('.rating-picker');
        var senderId   = $picker.data('sender-id');
        $picker.find('.rating-swatch').removeClass('active');
        $(this).addClass('active');
        $picker.find('.rating-picker-btn').css('background', color).attr('title', ratingName);
        $picker.find('.rating-picker-panel').removeClass('open');

        $.ajax({
            url:         '/Sender/UpdateRating',
            method:      'POST',
            contentType: 'application/json',
            headers:     { 'RequestVerificationToken': token },
            data:        JSON.stringify({ senderId: parseInt(senderId), ratingId: parseInt(ratingId) }),
            success: function (res) {
                if (res.success) {
                    $('#toast-msg').text('Rating saved: ' + res.ratingName);
                    $('#rating-toast').removeClass('bg-danger').addClass('bg-success text-white');
                } else {
                    $('#toast-msg').text('Error: ' + res.message);
                    $('#rating-toast').removeClass('bg-success').addClass('bg-danger text-white');
                }
                toast.show();
            },
            error: function () {
                $('#toast-msg').text('Network error — rating not saved.');
                $('#rating-toast').addClass('bg-danger text-white');
                toast.show();
            }
        });
    });
})();
</script>
}
