@model SenderSearchViewModel
@{ ViewData["Title"] = "Sender List"; }
@Html.AntiForgeryToken()

<!-- Toast -->
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div id="rating-toast" class="toast align-items-center border-0" role="alert">
        <div class="d-flex">
            <div class="toast-body" id="toast-msg">Rating saved.</div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<div class="card mb-2 border-0 shadow-sm">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <label class="form-label small fw-semibold mb-0" style="white-space:nowrap">Search</label>
            <input id="s-search" type="text" class="form-control form-control-sm" style="max-width:280px"
                   placeholder="Email or display name..." value="@Model.SearchTerm" />
        </div>

        <div class="d-flex flex-wrap align-items-center gap-2">
            <label class="form-label small fw-semibold mb-0" style="white-space:nowrap">Subset Name</label>
            <input id="subset-name" type="text" class="form-control form-control-sm" style="max-width:240px"
                   placeholder="e.g. New York Times" />
            <button id="save-subset-btn" type="button" class="btn btn-sm btn-outline-primary">Save Subset</button>

            <label class="form-label small fw-semibold mb-0 ms-2" style="white-space:nowrap">Load Subset</label>
            <select id="subset-select" class="form-select form-select-sm" style="max-width:260px">
                <option value="">(choose subset)</option>
            </select>
            <button id="clear-subset-btn" type="button" class="btn btn-sm btn-outline-secondary">Clear Selection</button>

            <span class="small text-muted ms-2">Selected: <strong id="subset-selected-count">0</strong></span>
        </div>
    </div>
</div>

@await Html.PartialAsync("_FilterBar", new FilterBarViewModel
{
    AvailableRatings = Model.AvailableRatings,
    SelectedRatings  = Model.RatingFilter,
    StatusFilter     = Model.StatusFilter,
    ShowDate         = false,
    ShowPriority     = false
})

<div class="d-flex justify-content-between align-items-center mb-2 px-1">
    <span class="text-muted small">@Model.TotalCount sender(s)</span>
</div>

<div id="sender-table-container">
    @await Html.PartialAsync("_SenderRows", Model)
</div>

@section Scripts {
<script>
    let sndTimer;
    let subsetSelected = new Set();

    function showSenderToast(message, ok) {
        $('#toast-msg').text(message);
        $('#rating-toast')
            .toggleClass('bg-success text-white', !!ok)
            .toggleClass('bg-danger text-white', !ok);
        toast.show();
    }

    function updateSubsetCount() {
        $('#subset-selected-count').text(subsetSelected.size);
    }

    function syncSubsetCheckboxes() {
        $('.subset-cb').each(function() {
            var senderId = parseInt($(this).val(), 10);
            $(this).prop('checked', subsetSelected.has(senderId));
        });
        updateSubsetCount();
    }

    function loadSubsetOptions(selectedId) {
        $.getJSON('/Sender/Subsets', function(items) {
            var $ddl = $('#subset-select');
            var current = selectedId || $ddl.val();
            $ddl.empty().append('<option value="">(choose subset)</option>');
            items.forEach(function(s) {
                var opt = $('<option></option>').val(s.subsetId).text(s.subsetName);
                if (String(current) === String(s.subsetId)) {
                    opt.prop('selected', true);
                    $('#subset-name').val(s.subsetName);
                }
                $ddl.append(opt);
            });
        });
    }

    function loadSubsetMembers(subsetId) {
        if (!subsetId) {
            subsetSelected = new Set();
            syncSubsetCheckboxes();
            return;
        }

        $.getJSON('/Sender/SubsetMembers?subsetId=' + encodeURIComponent(subsetId), function(res) {
            subsetSelected = new Set((res.senderIds || []).map(Number));
            syncSubsetCheckboxes();
        });
    }

    function refreshSenders(page) {
        const f = FilterBar.getValues();
        const params = $.param({
            searchTerm:   $('#s-search').val(),
            ratingFilter: f.ratingFilter,
            statusFilter: f.statusFilter,
            page:         page || 1,
            pageSize:     50
        });

        $.get('/Sender/Rows?' + params, function (html) {
            $('#sender-table-container').html(html);
            syncSubsetCheckboxes();
        });
    }

    $('#s-search').on('input', function() {
        clearTimeout(sndTimer);
        sndTimer = setTimeout(() => refreshSenders(1), 300);
    });

    FilterBar.onChange = function() { refreshSenders(1); };

    // Apply stored filter on initial page load
    (function() {
        var f = FilterBar.getValues();
        if (f.ratingFilter || f.statusFilter || f.dateFrom || f.dateTo) {
            refreshSenders(1);
        }
    })();

    $(document).on('click', '.page-btn', function() {
        refreshSenders(parseInt($(this).data('page')));
    });

    // Rating swatch click → AJAX save
    var toast = new bootstrap.Toast(document.getElementById('rating-toast'), { delay: 2000 });
    var token = $('input[name="__RequestVerificationToken"]').val();

    $(document).on('change', '.subset-cb', function() {
        var senderId = parseInt($(this).val(), 10);
        if ($(this).is(':checked')) {
            subsetSelected.add(senderId);
        } else {
            subsetSelected.delete(senderId);
        }
        updateSubsetCount();
    });

    $('#save-subset-btn').on('click', function() {
        var name = ($('#subset-name').val() || '').trim();
        var senderIds = Array.from(subsetSelected);

        if (!name) {
            showSenderToast('Enter a subset name first.', false);
            return;
        }
        if (!senderIds.length) {
            showSenderToast('Select at least one sender with the left-side checkbox.', false);
            return;
        }

        $.ajax({
            url: '/Sender/SaveSubset',
            method: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': token },
            data: JSON.stringify({ subsetName: name, senderIds: senderIds }),
            success: function(res) {
                if (!res.success) {
                    showSenderToast(res.message || 'Subset save failed.', false);
                    return;
                }
                showSenderToast('Subset saved: ' + res.subsetName + ' (' + res.count + ' sender(s)).', true);
                loadSubsetOptions(res.subsetId);
            },
            error: function() {
                showSenderToast('Network error while saving subset.', false);
            }
        });
    });

    $('#subset-select').on('change', function() {
        var subsetId = $(this).val();
        var selectedName = $('#subset-select option:selected').text();
        if (subsetId) {
            $('#subset-name').val(selectedName);
        }
        loadSubsetMembers(subsetId);
    });

    $('#clear-subset-btn').on('click', function() {
        subsetSelected = new Set();
        syncSubsetCheckboxes();
        $('#subset-select').val('');
    });


    $(document).on('click', '.rating-picker[data-mode="row"] .rating-swatch', function (e) {
        e.stopPropagation();
        var ratingId   = $(this).data('rating-id');
        var ratingName = $(this).data('rating-name');
        var color      = $(this).data('color');
        var $picker    = $(this).closest('.rating-picker');
        var senderId   = $picker.data('sender-id');
        $picker.find('.rating-swatch').removeClass('active');
        $(this).addClass('active');
        $picker.find('.rating-picker-btn').css('background', color).attr('title', ratingName);
        $picker.find('.rating-picker-panel').removeClass('open');

        $.ajax({
            url: '/Sender/UpdateRating', method: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': token },
            data: JSON.stringify({ senderId: parseInt(senderId), ratingId: parseInt(ratingId) }),
            success: function (res) {
                showSenderToast(res.success ? 'Rating saved: ' + res.ratingName : 'Error: ' + res.message, res.success);
                if (res.success && FilterBar.getValues().ratingFilter) {
                    setTimeout(function() { refreshSenders(1); }, 900);
                }
            },
            error: function () {
                showSenderToast('Network error - rating not saved.', false);
            }
        });
    });

    loadSubsetOptions();
    syncSubsetCheckboxes();
</script>
}
