@model SenderSearchViewModel
@{ ViewData["Title"] = "Senders"; }

<div class="card mb-4 border-0 shadow-sm">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small fw-semibold text-muted mb-1">Search</label>
                <input id="s-search" type="text" class="form-control form-control-sm"
                       placeholder="Email or display name…" value="@Model.SearchTerm" />
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold text-muted mb-1">Rating</label>
                @{
                    var ratingOptions = new System.Text.StringBuilder();
                    ratingOptions.Append("<option value=\"\">All Ratings</option>");
                    foreach (var r in Model.AvailableRatings)
                    {
                        var sel = (Model.RatingFilter == r.RatingName) ? " selected" : "";
                        ratingOptions.Append($"<option value=\"{r.RatingName}\"{sel}>{r.RatingName}</option>");
                    }
                }
                <select id="s-rating" class="form-select form-select-sm">
                    @Html.Raw(ratingOptions.ToString())
                </select>
            </div>
            <div class="col-md-1">
                <button id="s-clear" class="btn btn-outline-secondary btn-sm w-100">Clear</button>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-2 px-1">
    <span class="text-muted small">@Model.TotalCount sender(s)</span>
</div>

<div id="sender-table-container">
    @await Html.PartialAsync("_SenderRows", Model)
</div>

@section Scripts {
<script>
    let sndTimer;

    function refreshSenders(page) {
        const params = $.param({
            searchTerm:   $('#s-search').val(),
            ratingFilter: $('#s-rating').val(),
            page:         page || 1,
            pageSize:     50
        });
        loadPartial('/Sender/Rows?' + params, '#sender-table-container');
    }

    $('#s-search').on('input', function() {
        clearTimeout(sndTimer);
        sndTimer = setTimeout(() => refreshSenders(1), 300);
    });
    $('#s-rating').on('change', () => refreshSenders(1));
    $('#s-clear').on('click', function() {
        $('#s-search').val(''); $('#s-rating').val('');
        refreshSenders(1);
    });
    $(document).on('click', '.page-btn', function() {
        refreshSenders(parseInt($(this).data('page')));
    });
</script>
}
