@model MessageGroupedViewModel
@{ ViewData["Title"] = "CEA Reports"; }
@Html.AntiForgeryToken()

@section Styles {
<style>
    /* ── Filter / sort bar ───────────────────────────────────────── */
    .grp-bar {
        background: #fff;
        border: 1px solid #ced4da;
        padding: .75rem 1rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        flex-wrap: wrap;
        margin-bottom: 0;
    }
    .grp-bar .f-label {
        font-size: .67rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: #868e96;
        margin-bottom: .15rem;
    }
    .grp-bar .form-control, .grp-bar .form-select {
        border-radius: 0;
        font-size: .8rem;
        height: 30px;
        padding: .2rem .5rem;
    }
    #btn-clear {
        border-radius: 0;
        font-size: .75rem;
        height: 30px;
        padding: 0 .75rem;
    }
    .sort-btn {
        border-radius: 0;
        font-size: .75rem;
        height: 30px;
        padding: 0 .75rem;
        white-space: nowrap;
    }
    .sort-btn.active { background: #0d6efd; color: #fff; border-color: #0d6efd; }

    /* ── Status strip ────────────────────────────────────────────── */
    .grp-status {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #1e2533;
        color: #868e96;
        font-size: .72rem;
        font-weight: 500;
        letter-spacing: .4px;
        padding: .35rem 1rem;
        text-transform: uppercase;
    }
    .grp-status strong { color: #e9ecef; font-weight: 700; }

    /* ── Table shell ─────────────────────────────────────────────── */
    .grp-wrap {
        border: 1px solid #ced4da;
        border-top: none;
        background: #fff;
    }
    .grp-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }
    .grp-table .col-star    { width: 32px; }
    .grp-table .col-date    { width: 140px; }
    .grp-table .col-snippet { width: auto; }
    .grp-table thead th {
        background: #f1f3f5;
        padding: .45rem 1rem;
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: #868e96;
        border-bottom: 2px solid #dee2e6;
        white-space: nowrap;
    }

    /* ── Sender header row ───────────────────────────────────────── */
    .msg-sender-hdr td {
        background: #f1f3f5;
        padding: .5rem 1rem;
        border-top: 3px solid #dee2e6;
        border-bottom: 1px solid #dee2e6;
        font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
        font-size: .85rem;
        font-weight: 700;
        color: #212529;
    }
    .msg-sender-hdr .sender-count {
        font-size: .7rem;
        font-weight: 600;
        color: #868e96;
        margin-left: .5rem;
    }

    /* ── from_raw row ────────────────────────────────────────────── */
    .msg-raw td {
        background: #f8f9fa;
        padding: .3rem 1rem .3rem 1.25rem;
        border-bottom: 1px solid #e9ecef;
        font-size: 1rem;
        color: #495057;
        font-style: italic;
        text-decoration: underline;
        border-left: 3px solid #dee2e6;
    }

    /* ── Subject row ─────────────────────────────────────────────── */
    .msg-subject td {
        background: #fff;
        padding: .35rem 1rem .35rem 2rem;
        border-bottom: 1px solid #f1f3f5;
        font-size: .875rem;
        font-weight: 600;
        color: #212529;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    /* ── Leaf row ────────────────────────────────────────────────── */
    .msg-leaf td {
        background: #fff;
        padding: .2rem 1rem .2rem 2.75rem;
        border-bottom: 1px solid #f8f8f8;
        font-size: .775rem;
        color: #868e96;
    }
    .msg-leaf .cell-snippet {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* ── Priority star ───────────────────────────────────────────── */
    .btn-priority {
        background: none;
        border: none;
        padding: 0 2px;
        font-size: .85rem;
        color: #ced4da;
        cursor: pointer;
        line-height: 1;
    }
    .btn-priority:hover  { color: #ffc107; }
    .btn-priority.active { color: #ffc107; }

    /* ── Rating dots on sender header ───────────────────────────── */
    .cea-rating-dots { display: inline-flex; gap: 5px; align-items: center; margin-left: .6rem; vertical-align: middle; }
    .cea-dot {
        width: 13px; height: 13px; border-radius: 50%;
        cursor: pointer; border: 2px solid rgba(0,0,0,.15);
        display: inline-block; transition: all .1s;
        flex-shrink: 0;
    }
    .cea-dot:hover  { border-color: rgba(0,0,0,.5); transform: scale(1.2); }
    .cea-dot.active { border-color: #000; width: 18px; height: 18px; }

    /* ── Rating filter swatches ──────────────────────────────────── */
    .cea-filter-swatches { display: inline-flex; gap: 5px; align-items: center; }
    .cea-filter-dot {
        width: 18px; height: 18px; border-radius: 50%;
        cursor: pointer; border: 2px solid rgba(0,0,0,.15);
        display: inline-block; transition: transform .1s, border-color .1s;
    }
    .cea-filter-dot:hover  { border-color: rgba(0,0,0,.5); transform: scale(1.15); }
    .cea-filter-dot.active { border-color: #000; }
    .cea-filter-all {
        width: 18px; height: 18px; border-radius: 50%;
        background: linear-gradient(135deg, #adb5bd 50%, #e9ecef 50%);
        cursor: pointer; border: 2px solid rgba(0,0,0,.15);
        display: inline-block; font-size: .45rem; font-weight: 700;
        display: inline-flex; align-items: center; justify-content: center;
        color: #495057; transition: border-color .1s;
    }
    .cea-filter-all.active { border-color: #000; }

    /* ── Empty ───────────────────────────────────────────────────── */
    .grp-empty td {
        text-align: center;
        padding: 3rem;
        color: #868e96;
        font-size: .875rem;
    }

    /* ── Pagination ──────────────────────────────────────────────── */
    .grp-pager {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .6rem 1rem;
        border-top: 1px solid #dee2e6;
        background: #f8f9fa;
    }
    .grp-pager .page-link { border-radius: 0 !important; font-size: .775rem; }
    .grp-pager-info { font-size: .75rem; color: #868e96; }
</style>
}

@{
    string RatingParam()   => string.IsNullOrEmpty(Model.RatingFilter) ? "" : $"&ratingFilter={Uri.EscapeDataString(Model.RatingFilter)}";
    string StatusParam()   => string.IsNullOrEmpty(Model.StatusFilter) ? "" : $"&statusFilter={Uri.EscapeDataString(Model.StatusFilter)}";
    string PriorityParam() => Model.PriorityOnly ? "&priorityOnly=true" : "";
    string DateParam()     => (string.IsNullOrEmpty(Model.DateFrom) ? "" : $"&dateFrom={Uri.EscapeDataString(Model.DateFrom)}")
                            + (string.IsNullOrEmpty(Model.DateTo)   ? "" : $"&dateTo={Uri.EscapeDataString(Model.DateTo)}");

    string SortUrl(string by, bool asc) =>
        $"/Message/CeaReports?sortBy={by}&sortAsc={asc.ToString().ToLower()}&searchTerm={Uri.EscapeDataString(Model.SearchTerm ?? "")}{RatingParam()}{StatusParam()}{PriorityParam()}{DateParam()}&page=1&pageSize={Model.PageSize}";

    string PageUrl(int p) =>
        $"/Message/CeaReports?sortBy={Model.SortBy}&sortAsc={Model.SortAsc.ToString().ToLower()}&searchTerm={Uri.EscapeDataString(Model.SearchTerm ?? "")}{RatingParam()}{StatusParam()}{PriorityParam()}{DateParam()}&page={p}&pageSize={Model.PageSize}";
}

<!-- Filter / sort bar -->
<form method="get" action="/Message/CeaReports" class="grp-bar">
    <input type="hidden" name="sortBy"       value="@Model.SortBy" />
    <input type="hidden" name="sortAsc"      value="@Model.SortAsc.ToString().ToLower()" />
    <input type="hidden" name="pageSize" id="h-page-size" value="@Model.PageSize" />
    <input type="hidden" name="priorityOnly" id="h-priority" value="@Model.PriorityOnly.ToString().ToLower()" />
    <input type="hidden" name="dateFrom"     id="h-date-from" value="@Model.DateFrom" />
    <input type="hidden" name="dateTo"       id="h-date-to"   value="@Model.DateTo" />
    <input type="hidden" name="statusFilter" id="h-status"    value="@Model.StatusFilter" />

    <div>
        <div class="f-label">Search CEA</div>
        <input name="searchTerm" type="text" class="form-control" style="width:220px"
               placeholder="Email address…" value="@Model.SearchTerm" />
    </div>

    <div>
        <div class="f-label">Rating</div>
        <input type="hidden" name="ratingFilter" id="cea-rating-input" value="@Model.RatingFilter" />
        <div class="cea-filter-swatches">
            <span class="cea-filter-all @(string.IsNullOrEmpty(Model.RatingFilter) ? "active" : "")"
                  data-value="" title="All ratings">All</span>
            @foreach (var r in Model.AvailableRatings)
            {
                <span class="cea-filter-dot @(Model.RatingFilter == r.RatingName ? "active" : "")"
                      style="background:@r.ColorCode"
                      data-value="@r.RatingName"
                      title="@r.RatingName"></span>
            }
        </div>
    </div>

    <div>
        <div class="f-label">Status</div>
        <div class="btn-group">
            <button type="button" class="btn sort-btn cea-status-btn @(string.IsNullOrEmpty(Model.StatusFilter) ? "active" : "")"
                    data-value="">All</button>
            <button type="button" class="btn sort-btn cea-status-btn @(Model.StatusFilter == "OPEN"  ? "active" : "")"
                    style="@(Model.StatusFilter == "OPEN"  ? "background:#adb5bd;color:#fff;border-color:#adb5bd" : "")"
                    data-value="OPEN">○ Open</button>
            <button type="button" class="btn sort-btn cea-status-btn @(Model.StatusFilter == "RATED" ? "active" : "")"
                    style="@(Model.StatusFilter == "RATED" ? "background:#28a745;color:#fff;border-color:#28a745" : "")"
                    data-value="RATED">✓ Rated</button>
        </div>
    </div>

    <div>
        <div class="f-label">Sort by #Msg</div>
        <div class="btn-group">
            <a href="@SortUrl("count", false)"
               class="btn btn-outline-secondary sort-btn @(Model.SortBy == "count" && !Model.SortAsc ? "active" : "")">↓ Most</a>
            <a href="@SortUrl("count", true)"
               class="btn btn-outline-secondary sort-btn @(Model.SortBy == "count" && Model.SortAsc ? "active" : "")">↑ Least</a>
        </div>
    </div>

    <div>
        <div class="f-label">Sort by CEA</div>
        <div class="btn-group">
            <a href="@SortUrl("email", true)"
               class="btn btn-outline-secondary sort-btn @(Model.SortBy == "email" && Model.SortAsc ? "active" : "")">A → Z</a>
            <a href="@SortUrl("email", false)"
               class="btn btn-outline-secondary sort-btn @(Model.SortBy == "email" && !Model.SortAsc ? "active" : "")">Z → A</a>
        </div>
    </div>

    <div>
        <div class="f-label">Date From</div>
        <input type="date" id="ui-date-from" class="form-control" style="width:145px"
               value="@Model.DateFrom" />
    </div>
    <div>
        <div class="f-label">Date To</div>
        <input type="date" id="ui-date-to" class="form-control" style="width:145px"
               value="@Model.DateTo" />
    </div>

    <div>
        <div class="f-label">Per Page</div>
        <select id="sel-page-size" class="form-select" style="width:80px;border-radius:0;font-size:.8rem;height:30px;padding:.2rem .4rem">
            @foreach (var n in new[] { 10, 25, 50, 100 })
            {
                if (Model.PageSize == n) { <option value="@n" selected>@n</option> }
                else                     { <option value="@n">@n</option> }
            }
        </select>
    </div>

    <div class="d-flex align-items-end" style="margin-top:auto">
        <button type="button" id="btn-priority-toggle"
                class="btn sort-btn me-1 @(Model.PriorityOnly ? "btn-warning" : "btn-outline-secondary")"
                title="Show priority messages only">★ Priority</button>
        <button type="submit" class="btn btn-primary sort-btn me-1">Apply</button>
        <a href="/Message/CeaReports" class="btn btn-outline-secondary" id="btn-clear">Clear</a>
    </div>
</form>

<!-- Status strip -->
<div class="grp-status">
    <span>
        <strong>@Model.TotalSenders</strong> senders ·
        showing @((Model.Page - 1) * Model.PageSize + 1)–@(Math.Min(Model.Page * Model.PageSize, Model.TotalSenders))
        @if (!string.IsNullOrEmpty(Model.RatingFilter))
        {
            <span> · rating: <strong>@Model.RatingFilter</strong></span>
        }
        @if (!string.IsNullOrEmpty(Model.StatusFilter))
        {
            <span> · status: <strong>@Model.StatusFilter</strong></span>
        }
    </span>
    <span>
        Page <strong>@Model.Page</strong> of @Model.TotalPages ·
        sorted by
        <strong>@(Model.SortBy == "email" ? "email" : "#msg")</strong>
        @(Model.SortAsc ? "↑ asc" : "↓ desc")
    </span>
</div>

<!-- Tree table -->
<div class="grp-wrap">
    <table class="grp-table">
        <thead>
            <tr>
                <th class="col-star text-center">★</th>
                <th class="col-date">Date</th>
                <th class="col-snippet">Subject</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.CeaGroups.Any())
            {
                <tr class="grp-empty"><td colspan="3">No senders match your filters.</td></tr>
            }

            @foreach (var cea in Model.CeaGroups)
            {
                <!-- Sender header row -->
                <tr class="msg-sender-hdr" data-sender-id="@cea.SenderId">
                    <td colspan="3">
                        <button type="button"
                                class="status-btn @(cea.StatusName == "RATED" ? "rated" : "")"
                                data-sender-id="@cea.SenderId"
                                data-next-status-id="@(cea.StatusName == "RATED" ? 1 : 2)"
                                title="@cea.StatusName"
                                style="margin-right:.4rem;vertical-align:middle">@(cea.StatusName == "RATED" ? "✓" : "○")</button>
                        <a href="/Sender/Detail/@cea.SenderId" style="color:inherit;text-decoration:none">@cea.EmailAddress</a>
                        <span class="sender-count">@cea.MsgCount msg</span>
                        <span class="cea-rating-dots">
                            @foreach (var r in Model.AvailableRatings)
                            {
                                <span class="cea-dot @(r.RatingId == cea.RatingId ? "active" : "")"
                                      style="background:@r.ColorCode"
                                      data-sender-id="@cea.SenderId"
                                      data-rating-id="@r.RatingId"
                                      title="@r.RatingName"></span>
                            }
                        </span>
                    </td>
                </tr>

                @foreach (var rawGroup in cea.FromRawGroups)
                {
                    var rawDisplay = string.IsNullOrWhiteSpace(rawGroup.FromRaw)
                        ? "—"
                        : System.Text.RegularExpressions.Regex.Replace(rawGroup.FromRaw, @"\s*<[^>]+>", "").Trim();
                    if (string.IsNullOrWhiteSpace(rawDisplay)) rawDisplay = "—";

                    <tr class="msg-raw">
                        <td colspan="3">@rawDisplay</td>
                    </tr>

                    @foreach (var subjectGroup in rawGroup.Messages.GroupBy(m => m.Subject))
                    {
                        <tr class="msg-subject">
                            <td colspan="3">&#8226;&nbsp;@(subjectGroup.Key ?? "—")</td>
                        </tr>

                        @foreach (var m in subjectGroup.Where(m => !string.IsNullOrWhiteSpace(m.Snippet) || !string.IsNullOrWhiteSpace(m.InternalDate)))
                        {
                            <tr class="msg-leaf">
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(m.GmailMessageId))
                                    {
                                        <button class="btn-priority @(m.IsPriority ? "active" : "")"
                                                data-gmail-id="@m.GmailMessageId"
                                                title="Toggle priority">★</button>
                                    }
                                </td>
                                <td>@m.DisplayDate</td>
                                <td class="cell-snippet">@m.Snippet</td>
                            </tr>
                        }
                    }
                }
            }
        </tbody>
    </table>
</div>

<!-- Pagination -->
@if (Model.TotalPages > 1)
{
    <div class="grp-pager">
        <div>
            @if (Model.HasPrev)
            {
                <a class="btn btn-outline-secondary btn-sm" style="border-radius:0"
                   href="@PageUrl(Model.Page - 1)">‹ Prev 10</a>
            }
            else
            {
                <button class="btn btn-outline-secondary btn-sm" style="border-radius:0" disabled>‹ Prev 10</button>
            }
        </div>

        <nav>
            <ul class="pagination pagination-sm mb-0">
                @{
                    int pStart = Math.Max(1, Model.Page - 4);
                    int pEnd   = Math.Min(Model.TotalPages, pStart + 8);
                }
                @if (pStart > 1)
                {
                    <li class="page-item"><a class="page-link" href="@PageUrl(1)">1</a></li>
                    @if (pStart > 2) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                }
                @for (int p = pStart; p <= pEnd; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" href="@PageUrl(p)">@p</a>
                    </li>
                }
                @if (pEnd < Model.TotalPages)
                {
                    @if (pEnd < Model.TotalPages - 1) { <li class="page-item disabled"><span class="page-link">…</span></li> }
                    <li class="page-item"><a class="page-link" href="@PageUrl(Model.TotalPages)">@Model.TotalPages</a></li>
                }
            </ul>
        </nav>

        <div>
            @if (Model.HasNext)
            {
                <a class="btn btn-outline-secondary btn-sm" style="border-radius:0"
                   href="@PageUrl(Model.Page + 1)">Next 10 ›</a>
            }
            else
            {
                <button class="btn btn-outline-secondary btn-sm" style="border-radius:0" disabled>Next 10 ›</button>
            }
        </div>
    </div>
}

@section Scripts {
<script>
// Star toggle on individual messages
document.addEventListener('click', function (e) {
    const btn = e.target.closest('.btn-priority');
    if (!btn) return;
    const gmailId = btn.dataset.gmailId;
    fetch('/Message/TogglePriority', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(gmailId)
    })
    .then(r => r.json())
    .then(data => { btn.classList.toggle('active', data.isPriority); });
});

// Priority filter toggle
document.getElementById('btn-priority-toggle').addEventListener('click', function () {
    var h = document.getElementById('h-priority');
    h.value = h.value === 'true' ? 'false' : 'true';
    this.closest('form').submit();
});

// Page size dropdown
document.getElementById('sel-page-size').addEventListener('change', function () {
    document.getElementById('h-page-size').value = this.value;
    this.closest('form').submit();
});

// Date inputs — sync to hidden fields and submit
document.getElementById('ui-date-from').addEventListener('change', function () {
    document.getElementById('h-date-from').value = this.value;
    this.closest('form').submit();
});
document.getElementById('ui-date-to').addEventListener('change', function () {
    document.getElementById('h-date-to').value = this.value;
    this.closest('form').submit();
});

// Rating filter swatches
document.addEventListener('click', function (e) {
    const dot = e.target.closest('.cea-filter-dot, .cea-filter-all');
    if (!dot) return;
    const val = dot.dataset.value || '';
    document.querySelectorAll('.cea-filter-dot, .cea-filter-all').forEach(d => d.classList.remove('active'));
    dot.classList.add('active');
    document.getElementById('cea-rating-input').value = val;
    dot.closest('form').submit();
});

// Status filter buttons
document.querySelectorAll('.cea-status-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
        document.getElementById('h-status').value = this.dataset.value;
        this.closest('form').submit();
    });
});

// Sender rating dots — AJAX save
(function () {
    var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
    document.addEventListener('click', function (e) {
        const dot = e.target.closest('.cea-dot');
        if (!dot) return;
        e.stopPropagation();
        const senderId = parseInt(dot.dataset.senderId);
        const ratingId = parseInt(dot.dataset.ratingId);
        fetch('/Sender/UpdateRating', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
            body: JSON.stringify({ senderId, ratingId })
        })
        .then(r => r.json())
        .then(data => {
            if (data.success) {
                const row = dot.closest('tr');
                row.querySelectorAll('.cea-dot').forEach(d => d.classList.remove('active'));
                dot.classList.add('active');
            }
        });
    });
})();
</script>
}
