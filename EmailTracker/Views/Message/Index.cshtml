@model MessageSearchViewModel
@{ ViewData["Title"] = "Messages"; }

@section Styles {
<style>
    /* ── Status strip ────────────────────────────────────────────── */
    .msg-status {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #1e2533;
        color: #868e96;
        font-size: .72rem;
        font-weight: 500;
        letter-spacing: .4px;
        padding: .35rem 1rem;
        text-transform: uppercase;
    }
    .msg-status strong { color: #e9ecef; font-weight: 700; }

    /* ── Table shell ─────────────────────────────────────────────── */
    .msg-wrap {
        border: 1px solid #ced4da;
        border-top: none;
        background: #fff;
    }
    .msg-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }

    /* ── Column widths ───────────────────────────────────────────── */
    .msg-table .col-date    { width: 140px; }
    .msg-table .col-subject { width: auto; }

    /* ── Header ──────────────────────────────────────────────────── */
    .msg-table thead th {
        background: #f1f3f5;
        padding: .45rem 1rem;
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: #868e96;
        border-bottom: 2px solid #dee2e6;
        white-space: nowrap;
    }

    /* ── CEA row ─────────────────────────────────────────────────── */
    .msg-cea td {
        background: #fff;
        padding: .6rem 1rem;
        border-top: 3px solid #dee2e6;
        border-bottom: 1px solid #dee2e6;
        text-align: center;
    }
    .msg-cea-pill {
        display: inline-block;
        min-width: 320px;
        padding: .4rem 1.75rem;
        border-radius: 999px;
        text-align: center;
        line-height: 1.4;
        font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
    }
    .msg-cea-link {
        font-size: .85rem;
        font-weight: 700;
        color: inherit;
        text-decoration: none;
        letter-spacing: -.1px;
        word-break: break-all;
    }
    .msg-cea-link:hover { opacity: .85; text-decoration: underline; color: inherit; }
    .msg-cea-count {
        font-size: .7rem;
        font-weight: 700;
        margin-left: .6rem;
        background: rgba(0,0,0,.3);
        padding: .1rem .55rem;
        border-radius: 999px;
        color: #fff;
    }

    /* ── from_raw row ────────────────────────────────────────────── */
    .msg-raw td {
        background: #f8f9fa;
        padding: .3rem 1rem .3rem 1.25rem;
        border-bottom: 1px solid #e9ecef;
        font-size: 1rem;
        color: #495057;
        font-style: italic;
        text-decoration: underline;
        border-left: 3px solid #dee2e6;
    }

    /* ── Subject row ─────────────────────────────────────────────── */
    .msg-subject td {
        background: #fff;
        padding: .35rem 1rem .35rem 2rem;
        border-bottom: 1px solid #f1f3f5;
        font-size: .875rem;
        font-weight: 600;
        color: #212529;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    /* ── Leaf row ────────────────────────────────────────────────── */
    .msg-leaf td {
        background: #fff;
        padding: .2rem 1rem .2rem 2.75rem;
        border-bottom: 1px solid #f8f8f8;
        font-size: .775rem;
        color: #868e96;
    }
    .msg-leaf .cell-snippet {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* ── Empty state ─────────────────────────────────────────────── */
    .msg-empty td {
        text-align: center;
        padding: 3rem;
        color: #868e96;
        font-size: .875rem;
    }

    /* ── Pagination ──────────────────────────────────────────────── */
    .msg-pager {
        display: flex;
        justify-content: center;
        padding: .6rem;
        border-top: 1px solid #dee2e6;
        background: #f8f9fa;
    }
    .msg-pager .page-link { border-radius: 0 !important; font-size: .775rem; }
</style>
}

<!-- Search -->
<div class="card mb-2 border-0 shadow-sm">
    <div class="card-body py-2">
        <div class="d-flex align-items-center gap-2">
            <label class="form-label small fw-semibold text-muted mb-0" style="white-space:nowrap">Search</label>
            <input id="f-search" type="text" class="form-control form-control-sm" style="max-width:280px"
                   placeholder="Subject, sender, snippet…" value="@Model.SearchTerm" />
        </div>
    </div>
</div>

@await Html.PartialAsync("_FilterBar", new FilterBarViewModel
{
    AvailableRatings = Model.AvailableRatings,
    SelectedRatings  = Model.RatingFilter,
    StatusFilter     = Model.StatusFilter,
    DateFrom         = Model.DateFrom,
    DateTo           = Model.DateTo,
    ShowPriority     = false
})

<!-- Status strip -->
<div class="msg-status">
    <span><strong id="result-count">@Model.TotalCount</strong> messages</span>
    <span>Page <strong id="page-indicator">@Model.Page</strong> of @Model.TotalPages</span>
</div>

<!-- Table -->
<div class="msg-wrap">
    <div id="message-table-container">
        @await Html.PartialAsync("_MessageRows", Model)
    </div>
</div>

@section Scripts {
<script>
    let msgTimer, currentPage = 1;

    function refresh(page) {
        currentPage = page || 1;
        const f = FilterBar.getValues();
        const params = $.param({
            searchTerm:   $('#f-search').val(),
            ratingFilter: f.ratingFilter,
            statusFilter: f.statusFilter,
            dateFrom:     f.dateFrom,
            dateTo:       f.dateTo,
            page:         currentPage,
            pageSize:     50
        });
        $.get('/Message/Rows?' + params, function(html) {
            $('#message-table-container').html(html);
            $('#page-indicator').text(currentPage);
        });
    }

    $('#f-search').on('input', function() {
        clearTimeout(msgTimer);
        msgTimer = setTimeout(() => refresh(1), 300);
    });

    FilterBar.onChange = function() { refresh(1); };

    $(document).on('click', '.page-btn', function() {
        refresh(parseInt($(this).data('page')));
    });
</script>
}
