@model MessageSearchViewModel
@{ ViewData["Title"] = "Messages"; }

@section Styles {
<style>
    /* ── Filter bar ──────────────────────────────────────────────── */
    .msg-filter {
        background: #fff;
        border: 1px solid #ced4da;
        padding: .875rem 1rem;
        margin-bottom: 0;
    }
    .msg-filter .f-label {
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .65px;
        color: #868e96;
        margin-bottom: .2rem;
    }
    .msg-filter .form-control,
    .msg-filter .form-select {
        border-radius: 0;
        border-color: #ced4da;
        font-size: .8rem;
        height: 30px;
        padding: .2rem .5rem;
    }
    .msg-filter .form-control:focus,
    .msg-filter .form-select:focus {
        box-shadow: none;
        border-color: #0d6efd;
    }
    #btn-clear {
        border-radius: 0;
        font-size: .75rem;
        height: 30px;
        padding: 0 .75rem;
    }

    /* ── Status strip ────────────────────────────────────────────── */
    .msg-status {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #1e2533;
        color: #868e96;
        font-size: .72rem;
        font-weight: 500;
        letter-spacing: .4px;
        padding: .35rem 1rem;
        text-transform: uppercase;
    }
    .msg-status strong { color: #e9ecef; font-weight: 700; }

    /* ── Table shell ─────────────────────────────────────────────── */
    .msg-wrap {
        border: 1px solid #ced4da;
        border-top: none;
        background: #fff;
    }
    .msg-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }

    /* ── Column widths ───────────────────────────────────────────── */
    .msg-table .col-date    { width: 140px; }
    .msg-table .col-subject { width: auto; }

    /* ── Header ──────────────────────────────────────────────────── */
    .msg-table thead th {
        background: #f1f3f5;
        padding: .45rem 1rem;
        font-size: .68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .6px;
        color: #868e96;
        border-bottom: 2px solid #dee2e6;
        white-space: nowrap;
    }

    /* ── CEA row ─────────────────────────────────────────────────── */
    .msg-cea td {
        background: #fff;
        padding: .6rem 1rem;
        border-top: 3px solid #dee2e6;
        border-bottom: 1px solid #dee2e6;
        text-align: center;
    }
    .msg-cea-pill {
        display: inline-block;
        min-width: 320px;
        padding: .4rem 1.75rem;
        border-radius: 999px;
        text-align: center;
        line-height: 1.4;
        font-family: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
    }
    .msg-cea-link {
        font-size: .85rem;
        font-weight: 700;
        color: inherit;
        text-decoration: none;
        letter-spacing: -.1px;
        word-break: break-all;
    }
    .msg-cea-link:hover { opacity: .85; text-decoration: underline; color: inherit; }
    .msg-cea-count {
        font-size: .7rem;
        font-weight: 700;
        margin-left: .6rem;
        background: rgba(0,0,0,.3);
        padding: .1rem .55rem;
        border-radius: 999px;
        color: #fff;
    }

    /* ── from_raw row ────────────────────────────────────────────── */
    .msg-raw td {
        background: #f8f9fa;
        padding: .3rem 1rem .3rem 1.25rem;
        border-bottom: 1px solid #e9ecef;
        font-size: 1rem;
        color: #495057;
        font-style: italic;
        text-decoration: underline;
        border-left: 3px solid #dee2e6;
    }

    /* ── Subject row ─────────────────────────────────────────────── */
    .msg-subject td {
        background: #fff;
        padding: .35rem 1rem .35rem 2rem;
        border-bottom: 1px solid #f1f3f5;
        font-size: .875rem;
        font-weight: 600;
        color: #212529;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }
    /* ── Leaf row ────────────────────────────────────────────────── */
    .msg-leaf td {
        background: #fff;
        padding: .2rem 1rem .2rem 2.75rem;
        border-bottom: 1px solid #f8f8f8;
        font-size: .775rem;
        color: #868e96;
    }
    .msg-leaf .cell-snippet {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* ── Empty state ─────────────────────────────────────────────── */
    .msg-empty td {
        text-align: center;
        padding: 3rem;
        color: #868e96;
        font-size: .875rem;
    }

    /* ── Pagination ──────────────────────────────────────────────── */
    .msg-pager {
        display: flex;
        justify-content: center;
        padding: .6rem;
        border-top: 1px solid #dee2e6;
        background: #f8f9fa;
    }
    .msg-pager .page-link { border-radius: 0 !important; font-size: .775rem; }
</style>
}

<!-- Filter bar -->
<div class="msg-filter">
    <div class="row g-2 align-items-end">
        <div class="col-md-4">
            <div class="f-label">Search</div>
            <input id="f-search" type="text" class="form-control"
                   placeholder="Subject, sender, snippet…" value="@Model.SearchTerm" />
        </div>
        <div class="col-md-2">
            <div class="f-label">Rating</div>
            @{
                var ratingOpts = new System.Text.StringBuilder();
                ratingOpts.Append("<option value=\"\">All Ratings</option>");
                foreach (var r in Model.AvailableRatings)
                {
                    var sel = (Model.RatingFilter == r.RatingName) ? " selected" : "";
                    ratingOpts.Append($"<option value=\"{r.RatingName}\"{sel}>{r.RatingName}</option>");
                }
            }
            <select id="f-rating" class="form-select">@Html.Raw(ratingOpts.ToString())</select>
        </div>
        <div class="col-md-2">
            <div class="f-label">Date From</div>
            <input id="f-date-from" type="date" class="form-control" value="@Model.DateFrom" />
        </div>
        <div class="col-md-2">
            <div class="f-label">Date To</div>
            <input id="f-date-to" type="date" class="form-control" value="@Model.DateTo" />
        </div>
        <div class="col-md-1 d-flex align-items-end">
            <button id="btn-clear" class="btn btn-outline-secondary w-100">
                <i class="fas fa-times me-1"></i>Clear
            </button>
        </div>
    </div>
</div>

<!-- Status strip -->
<div class="msg-status">
    <span><strong id="result-count">@Model.TotalCount</strong> messages</span>
    <span>Page <strong id="page-indicator">@Model.Page</strong> of @Model.TotalPages</span>
</div>

<!-- Table -->
<div class="msg-wrap">
    <div id="message-table-container">
        @await Html.PartialAsync("_MessageRows", Model)
    </div>
</div>

@section Scripts {
<script>
    let msgTimer, currentPage = 1;

    function getFilters(page) {
        return {
            searchTerm:   $('#f-search').val(),
            ratingFilter: $('#f-rating').val(),
            dateFrom:     $('#f-date-from').val(),
            dateTo:       $('#f-date-to').val(),
            page:         page || 1,
            pageSize:     50
        };
    }

    function refresh(page) {
        currentPage = page || 1;
        const params = $.param(getFilters(currentPage));
        $.get('/Message/Rows?' + params, function(html) {
            $('#message-table-container').html(html);
            $('#page-indicator').text(currentPage);
        });
    }

    function updateCount(total) {
        $('#result-count').text(total);
    }

    $('#f-search').on('input', function() {
        clearTimeout(msgTimer);
        msgTimer = setTimeout(() => refresh(1), 300);
    });

    $('#f-rating, #f-date-from, #f-date-to').on('change', () => refresh(1));

    $('#btn-clear').on('click', function() {
        $('#f-search, #f-date-from, #f-date-to').val('');
        $('#f-rating').val('');
        refresh(1);
    });

    $(document).on('click', '.page-btn', function() {
        refresh(parseInt($(this).data('page')));
    });
</script>
}
