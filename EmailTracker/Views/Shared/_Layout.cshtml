<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"] — Email Tracker</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --sidebar-width: 220px;
            --sidebar-collapsed-width: 52px;
            --accent: #0d6efd;
            --sidebar-bg: #1a1d23;
            --sidebar-text: #adb5bd;
            --muted: #444;
            --label: #333;
            --sublabel: #444;
        }
        /* Global muted text override — replaces Bootstrap's washed-out #868e96 */
        .text-muted, small.text-muted { color: #444 !important; }
        small { color: #444; }
        html { font-size: 16px; }
        body { display: flex; min-height: 100vh; background: #f8f9fa; font-family: 'Segoe UI', sans-serif; font-size: 1rem; }

        /* Sidebar */
        #sidebar {
            width: var(--sidebar-width); background: var(--sidebar-bg);
            color: var(--sidebar-text); display: flex; flex-direction: column;
            position: fixed; top: 0; left: 0; height: 100vh; z-index: 100;
            transition: width .2s ease; overflow: hidden;
        }
        #sidebar.collapsed { width: var(--sidebar-collapsed-width); }

        .sidebar-toggle-row {
            display: flex; justify-content: flex-end;
            padding: .5rem .75rem .25rem;
        }
        #btn-sidebar-toggle {
            background: none; border: none; color: #adb5bd; cursor: pointer;
            padding: 0; font-size: .85rem; line-height: 1;
        }
        #btn-sidebar-toggle:hover { color: #fff; }
        #sidebar .brand {
            padding: .5rem 1.5rem .75rem; font-size: 1rem; font-weight: 700;
            color: #fff; border-bottom: 1px solid #2d3139; letter-spacing: .5px;
            white-space: nowrap; min-width: var(--sidebar-width);
        }
        #sidebar .brand span { color: var(--accent); }

        #sidebar nav { flex: 1; padding: .75rem 0; overflow: hidden; }
        #sidebar nav a {
            display: flex; align-items: center; gap: .75rem;
            padding: .65rem 1.5rem; color: var(--sidebar-text);
            text-decoration: none; font-size: .95rem;
            white-space: nowrap; min-width: var(--sidebar-width);
        }
        #sidebar nav a.active {
            color: #fff; background: #0d6efd22;
            border-left: 3px solid var(--accent);
        }
        #sidebar nav a i { width: 16px; text-align: center; flex-shrink: 0; }
        #sidebar .sidebar-footer {
            padding: 1rem 1.5rem; font-size: .75rem;
            color: #444; border-top: 1px solid #2d3139;
            white-space: nowrap; min-width: var(--sidebar-width);
        }

        /* Main content */
        #main { margin-left: var(--sidebar-width); flex: 1; display: flex; flex-direction: column; transition: margin-left .2s ease; }
        #main.sidebar-collapsed { margin-left: var(--sidebar-collapsed-width); }
        #topbar {
            background: #fff; border-bottom: 1px solid #dee2e6;
            padding: .75rem 1.5rem; display: flex; align-items: center;
            justify-content: space-between; position: sticky; top: 0; z-index: 50;
        }
        #topbar h1 { font-size: 1.2rem; font-weight: 600; margin: 0; color: #212529; }
        #content { padding: 1.5rem; flex: 1; color: #212529; font-size: 1rem; }

        /* Darker content text */
        #content .text-muted { color: #555 !important; }
        #content small.text-muted { color: #666 !important; }
        .table-card .table tbody td { color: #212529; }
        .table-card .table thead th { color: #444; }

        /* Cards */
        .stat-card { border: none; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
        .stat-card .card-body { padding: 1.25rem; }
        .stat-number { font-size: 2rem; font-weight: 700; line-height: 1; }
        .stat-label  { font-size: .8rem; color: #6c757d; margin-top: .25rem; }

        /* Tables */
        .table-card { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.08); overflow: hidden; }
        .table-card .table { margin: 0; font-size: .95rem; }
        .table-card .table thead th {
            background: #f8f9fa; border-bottom: 2px solid #dee2e6;
            font-weight: 600; font-size: .875rem; text-transform: uppercase;
            letter-spacing: .5px; color: #495057;
        }
        .table-card .table tbody tr:hover { background: #f0f4ff; cursor: pointer; }

        /* Rating badges */
        .badge-rating { font-size: .75rem; padding: .3em .65em; border-radius: 20px; }

        /* Loading spinner overlay */
        #ajax-spinner {
            display: none; position: fixed; top: 50%; left: 50%;
            transform: translate(-50%,-50%); z-index: 9999;
        }
        #ajax-spinner .spinner-border { width: 3rem; height: 3rem; }

        /* Pagination */
        .pagination { margin: 0; }
        .pagination .page-link { font-size: .875rem; }

        /* ── Large/Dark reading mode ── */
        body.reading-mode { font-size: 1.15rem; }
        body.reading-mode #content { font-size: 1.15rem; color: #111 !important; }
        body.reading-mode .table-card .table { font-size: 1.05rem; }
        body.reading-mode .table-card .table tbody td { color: #111 !important; font-size: 1.05rem; }
        body.reading-mode .table-card .table thead th { color: #222 !important; font-size: .95rem; }
        body.reading-mode .badge, body.reading-mode .btn { font-size: 1rem; }
        body.reading-mode p, body.reading-mode span:not(.badge),
        body.reading-mode div, body.reading-mode label,
        body.reading-mode a:not(#sidebar nav a) { color: #111 !important; }
        body.reading-mode .text-muted,
        body.reading-mode small.text-muted { color: #444 !important; }
        body.reading-mode .stat-label { color: #444 !important; font-size: .95rem; }
        body.reading-mode .stat-number { font-size: 2.4rem; }
        body.reading-mode .pagination .page-link { font-size: 1.05rem; padding: .45rem .8rem; }
        body.reading-mode #topbar h1 { font-size: 1.4rem; }
        body.reading-mode #topbar small { color: #444 !important; font-size: 1rem; }
        body.reading-mode .card-title, body.reading-mode .card-text { color: #111 !important; }
        body.reading-mode #sidebar nav a { font-size: 1.05rem; padding: .75rem 1.5rem; }
        #btn-reading-mode {
            background: none; border: 1px solid #dee2e6; border-radius: 6px;
            padding: .25rem .6rem; font-size: .85rem; cursor: pointer;
            color: #666; transition: all .15s;
        }
        #btn-reading-mode:hover { background: #f0f0f0; }
        body.reading-mode #btn-reading-mode { background: #ffc; border-color: #aaa; color: #222; font-weight: 600; }

        /* Status toggle button (shared across pages) */
        .status-btn {
            width: 20px; height: 20px; border-radius: 50%;
            border: 2px solid #adb5bd; background: #adb5bd;
            cursor: pointer; font-size: 11px; line-height: 1;
            color: #fff; padding: 0; transition: all .15s;
        }
        .status-btn:hover { border-color: #868e96; background: #868e96; }
        .status-btn.rated { border-color: #28a745; background: #28a745; color: #fff; }

        /* Rating color picker (shared across pages) */
        .rating-picker { position: relative; display: inline-block; }
        .rating-picker-btn {
            width: 36px; height: 26px;
            border: 2px solid #ced4da; border-radius: 3px;
            cursor: pointer; background: #e9ecef; padding: 0;
        }
        .rating-picker-btn.has-color { border-color: rgba(0,0,0,.3); }
        .rating-picker-panel {
            display: none; position: absolute;
            top: calc(100% + 4px); left: 0; z-index: 1050;
            background: #fff; border: 1px solid #ced4da;
            border-radius: 4px; padding: 5px;
            box-shadow: 0 2px 8px rgba(0,0,0,.18);
            flex-direction: row; gap: 5px; align-items: center;
        }
        .rating-picker-panel.open { display: flex; }
        /* Panel background is click-transparent so clicks pass through to rows beneath */
        .rating-picker-panel { pointer-events: none; }
        .rating-picker-panel .rating-swatch { pointer-events: auto; }
        .rating-swatch {
            width: 24px; height: 24px; border-radius: 3px;
            cursor: pointer; border: 2px solid rgba(0,0,0,.15);
            flex-shrink: 0; transition: transform .1s, border-color .1s;
        }
        .rating-swatch:hover { border-color: rgba(0,0,0,.55); transform: scale(1.15); }
        .rating-swatch.active { border-color: #000; }

        /* ── Global filter strip ── */
        #global-filter-strip {
            background: #e8f0fe; border-bottom: 1px solid #c5d4f5;
            padding: .3rem 1.5rem; display: none;
            align-items: center; gap: .5rem; flex-wrap: wrap; font-size: .78rem;
        }
        .gf-label {
            font-weight: 700; color: #444; text-transform: uppercase;
            font-size: .65rem; letter-spacing: .4px; white-space: nowrap; flex-shrink: 0;
        }
        .gf-pill {
            display: inline-flex; align-items: center; gap: .3rem;
            background: #fff; border: 1px solid #c5d4f5; border-radius: 999px;
            padding: .1rem .5rem; color: #333; font-weight: 600;
            white-space: nowrap; font-size: .72rem;
        }
        .gf-swatch {
            width: 10px; height: 10px; border-radius: 2px;
            display: inline-block; flex-shrink: 0;
        }
        #gf-clear {
            margin-left: auto; background: none; border: 1px solid #aab4e0;
            border-radius: 4px; padding: .15rem .5rem; font-size: .72rem;
            color: #444; cursor: pointer; white-space: nowrap;
        }
        #gf-clear:hover { background: #f0f0f0; }

        /* ── Top menubar ── */
        #menubar {
            background: #fff; border-bottom: 1px solid #dee2e6;
            padding: 0 1rem; display: flex; align-items: center; gap: 0;
            font-size: .85rem; position: sticky; top: 0; z-index: 49;
        }
        #topbar { z-index: 48; position: relative; }
        .menubar-item {
            display: inline-flex; align-items: center; gap: .4rem;
            padding: .5rem .85rem; color: #495057; text-decoration: none;
            border: none; background: none; cursor: pointer; font-size: .85rem;
            font-family: inherit; white-space: nowrap; transition: background .12s, color .12s;
        }
        .menubar-item:hover { background: #f0f4ff; color: #0d6efd; }
        .menubar-item.active { color: #0d6efd; font-weight: 600; box-shadow: inset 0 -2px 0 #0d6efd; }
        .menubar-item i { font-size: .8rem; }
        .menubar-dropdown { position: relative; }
        .menubar-dropdown-panel {
            display: none; position: absolute; top: 100%; left: 0;
            background: #fff; border: 1px solid #dee2e6; border-radius: 6px;
            box-shadow: 0 4px 12px rgba(0,0,0,.12); min-width: 190px;
            padding: .35rem 0; z-index: 200;
        }
        .menubar-dropdown:hover .menubar-dropdown-panel,
        .menubar-dropdown.open .menubar-dropdown-panel { display: block; }
        .menubar-dropdown-panel a {
            display: flex; align-items: center; gap: .5rem;
            padding: .45rem 1rem; color: #333; text-decoration: none;
            font-size: .85rem; white-space: nowrap;
        }
        .menubar-dropdown-panel a:hover { background: #f0f4ff; color: #0d6efd; }
        .menubar-dropdown-panel a i { width: 16px; text-align: center; color: #888; font-size: .8rem; }

        body.reading-mode #menubar { font-size: .95rem; }
        body.reading-mode .menubar-item { font-size: .95rem; padding: .55rem .95rem; }
        body.reading-mode .menubar-dropdown-panel a { font-size: .95rem; }

        /* ── Print ───────────────────────────────────────────────── */
        @@media print {
            body { display: block; background: #fff; font-size: 11pt; }
            #sidebar, #topbar, #menubar, #global-filter-strip,
            #ajax-spinner, .sidebar-footer, #btn-reading-mode,
            #btn-sidebar-toggle { display: none !important; }
            #main { margin-left: 0 !important; }
            #content { padding: .25in .35in; }
            a { color: inherit !important; text-decoration: none !important; }
            .text-muted, small.text-muted, small { color: #333 !important; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Sidebar -->
<aside id="sidebar">
    <div class="sidebar-toggle-row">
        <button id="btn-sidebar-toggle" title="Toggle sidebar"><i class="fas fa-chevron-left"></i></button>
    </div>
    <div class="brand">
        <span>📧 Email<span>Tracker</span></span>
    </div>
    <nav>
        <a asp-controller="Home"    asp-action="Index"  class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home"    ? "active" : "")">
            <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a asp-controller="Run"     asp-action="Index"  class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Run"     ? "active" : "")">
            <i class="fas fa-layer-group"></i> Runs
        </a>
        <a asp-controller="Message" asp-action="Index"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Message" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
            <i class="fas fa-envelope"></i> Messages
        </a>
        <a asp-controller="Message" asp-action="Grouped"
           class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Grouped" ? "active" : "")">
            <i class="fas fa-layer-group"></i> CEA Groups
        </a>
        <a asp-controller="Message" asp-action="CeaReports"
           class="@(ViewContext.RouteData.Values["action"]?.ToString() == "CeaReports" ? "active" : "")">
            <i class="fas fa-file-alt"></i> CEA Reports
        </a>
        <a asp-controller="Message" asp-action="Browse"
           class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Browse" && ViewContext.RouteData.Values["controller"]?.ToString() == "Message" ? "active" : "")">
            <i class="fas fa-address-card"></i> Msg Browse
        </a>
        <a asp-controller="Sender"  asp-action="Index"  class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Sender" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
            <i class="fas fa-users"></i> Sender List
        </a>
        <a asp-controller="Sender"  asp-action="Browse" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Browse" ? "active" : "")">
            <i class="fas fa-address-card"></i> Browse Senders
        </a>
        <a asp-controller="Sender"  asp-action="Index"  class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Summary" ? "active" : "")"
           title="Pick a sender from the list to view their summary">
            <i class="fas fa-layer-group"></i> Sender Summary
        </a>
        <a asp-controller="Sender"  asp-action="QuickRate" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "QuickRate" ? "active" : "")">
            <i class="fas fa-star-half-alt"></i> Quick Rate
        </a>
        <hr style="border-color:#2d3139;margin:.5rem 1rem" />
        <a asp-controller="GmailIngest" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "GmailIngest" ? "active" : "")">
            <i class="fas fa-download"></i> Gmail Ingest
        </a>
    </nav>
    <div class="sidebar-footer">v1.0 · SQLite</div>
</aside>

<!-- Main -->
<div id="main">
    <header id="topbar">
        <h1>@ViewData["Title"]</h1>
        <div style="display:flex;align-items:center;gap:.75rem">
            <button id="btn-reading-mode" title="Toggle large/dark reading mode">🔎 Reading Mode</button>
            <small class="text-muted">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</small>
        </div>
    </header>
    <nav id="menubar">
        <a asp-controller="Home" asp-action="Index"
           class="menubar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
            <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a asp-controller="Run" asp-action="Index"
           class="menubar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Run" ? "active" : "")">
            <i class="fas fa-layer-group"></i> Runs
        </a>
        <div class="menubar-dropdown">
            <button class="menubar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Message" ? "active" : "")">
                <i class="fas fa-envelope"></i> Messages <i class="fas fa-caret-down" style="font-size:.7rem;opacity:.6"></i>
            </button>
            <div class="menubar-dropdown-panel">
                <a asp-controller="Message" asp-action="Index"><i class="fas fa-envelope"></i> All Messages</a>
                <a asp-controller="Message" asp-action="Grouped"><i class="fas fa-layer-group"></i> CEA Groups</a>
                <a asp-controller="Message" asp-action="CeaReports"><i class="fas fa-file-alt"></i> CEA Reports</a>
                <a asp-controller="Message" asp-action="Browse"><i class="fas fa-address-card"></i> Msg Browse</a>
            </div>
        </div>
        <div class="menubar-dropdown">
            <button class="menubar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "Sender" ? "active" : "")">
                <i class="fas fa-users"></i> Senders <i class="fas fa-caret-down" style="font-size:.7rem;opacity:.6"></i>
            </button>
            <div class="menubar-dropdown-panel">
                <a asp-controller="Sender" asp-action="Index"><i class="fas fa-users"></i> Sender List</a>
                <a asp-controller="Sender" asp-action="Browse"><i class="fas fa-address-card"></i> Browse Senders</a>
                <a asp-controller="Sender" asp-action="QuickRate"><i class="fas fa-star-half-alt"></i> Quick Rate</a>
            </div>
        </div>
        <a asp-controller="GmailIngest" asp-action="Index"
           class="menubar-item @(ViewContext.RouteData.Values["controller"]?.ToString() == "GmailIngest" ? "active" : "")">
            <i class="fas fa-download"></i> Ingest
        </a>
    </nav>
    <div id="global-filter-strip">
        <span class="gf-label">Active Filter:</span>
        <div id="gf-pills" style="display:flex;align-items:center;gap:.4rem;flex-wrap:wrap"></div>
        <button id="gf-clear">✕ Clear All</button>
    </div>
    <main id="content">
        @RenderBody()
    </main>
</div>

<!-- AJAX spinner -->
<div id="ajax-spinner">
    <div class="spinner-border text-primary"></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script>
    // Rating color picker — open/close (shared)
    $(document).on('click', '.rating-picker-btn', function (e) {
        e.stopPropagation();
        var $panel = $(this).closest('.rating-picker').find('.rating-picker-panel');
        var wasOpen = $panel.hasClass('open');
        $('.rating-picker-panel').removeClass('open');
        if (!wasOpen) $panel.addClass('open');
    });
    $(document).on('click', function () { $('.rating-picker-panel').removeClass('open'); });

    // Status toggle — shared across all pages
    $(document).on('click', '.status-btn', function () {
        var $btn     = $(this);
        var senderId = parseInt($btn.data('sender-id'));
        var nextId   = parseInt($btn.data('next-status-id'));
        var token    = $('input[name="__RequestVerificationToken"]').val();
        $.ajax({
            url: '/Sender/SetStatus', method: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': token },
            data: JSON.stringify({ senderId: senderId, statusId: nextId }),
            success: function (res) {
                if (res.success) {
                    var nowRated = res.statusName === 'RATED';
                    $btn.toggleClass('rated', nowRated)
                        .text(nowRated ? '✓' : '○')
                        .attr('title', res.statusName)
                        .data('next-status-id', nowRated ? 1 : 2);
                    if (typeof FilterBar !== 'undefined' && typeof FilterBar.onChange === 'function'
                            && FilterBar.getValues().statusFilter) {
                        setTimeout(function() { FilterBar.onChange(); }, 900);
                    }
                }
            }
        });
    });

    // Reading mode toggle
    (function () {
        var on = localStorage.getItem('reading-mode') === '1';
        function apply(v) { $('body').toggleClass('reading-mode', v); }
        apply(on);
        $('#btn-reading-mode').on('click', function () {
            on = !on;
            localStorage.setItem('reading-mode', on ? '1' : '0');
            apply(on);
        });
    })();

    // Sidebar collapse
    (function () {
        var collapsed = localStorage.getItem('sidebar-collapsed') === '1';
        function apply(c) {
            $('#sidebar').toggleClass('collapsed', c);
            $('#main').toggleClass('sidebar-collapsed', c);
            $('#btn-sidebar-toggle i')
                .toggleClass('fa-chevron-left', !c)
                .toggleClass('fa-chevron-right', c);
        }
        apply(collapsed);
        $('#btn-sidebar-toggle').on('click', function () {
            collapsed = !collapsed;
            localStorage.setItem('sidebar-collapsed', collapsed ? '1' : '0');
            apply(collapsed);
        });
    })();

    // Global AJAX helpers
    $(document).ajaxStart(() => $('#ajax-spinner').show())
               .ajaxStop(()  => $('#ajax-spinner').hide());

    function loadPartial(url, targetSelector) {
        $.get(url, function(html) {
            $(targetSelector).html(html);
        });
    }

    // ── Global filter strip ──────────────────────────────────────
    (function () {
        var LS_KEY   = 'et-filter';
        var strip    = document.getElementById('global-filter-strip');
        var pills    = document.getElementById('gf-pills');
        var clearBtn = document.getElementById('gf-clear');

        function renderStrip(v) {
            if (!v || !(v.statusFilter || v.dateFrom || v.dateTo || v.ratingFilter || v.priorityOnly)) {
                strip.style.display = 'none';
                return;
            }
            var html = '';
            if (v.statusFilter) {
                html += '<span class="gf-pill">Status: ' + (v.statusFilter === 'OPEN' ? '○ Open' : '✓ Rated') + '</span>';
            }
            if (v.dateFrom || v.dateTo) {
                html += '<span class="gf-pill">Date: ' + (v.dateFrom || '…') + ' → ' + (v.dateTo || '…') + '</span>';
            }
            if (v.ratingFilter) {
                var colors = v.ratingColors || {};
                v.ratingFilter.split(',').filter(function(x){return x;}).forEach(function(name) {
                    html += '<span class="gf-pill"><span class="gf-swatch" style="background:' + (colors[name] || '#adb5bd') + '"></span>' + name + '</span>';
                });
            }
            if (v.priorityOnly) {
                html += '<span class="gf-pill">★ Priority</span>';
            }
            pills.innerHTML = html;
            strip.style.display = 'flex';
        }

        // Init from localStorage on every page
        try { renderStrip(JSON.parse(localStorage.getItem(LS_KEY))); } catch(e) {}

        // Real-time updates from FilterBar (same-page changes)
        window.addEventListener('et-filter-changed', function(e) { renderStrip(e.detail); });

        // Clear All: remove state, hide strip, trigger FilterBar clear if present
        clearBtn.addEventListener('click', function() {
            try { localStorage.removeItem(LS_KEY); } catch(e) {}
            renderStrip(null);
            var fbClear = document.getElementById('fb-clear');
            if (fbClear) fbClear.click();
        });
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)
