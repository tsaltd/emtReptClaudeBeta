<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>@ViewData["Title"] — Email Tracker</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <style>
        :root {
            --sidebar-width: 220px;
            --sidebar-collapsed-width: 52px;
            --accent: #0d6efd;
            --sidebar-bg: #1a1d23;
            --sidebar-text: #adb5bd;
        }
        body { display: flex; min-height: 100vh; background: #f8f9fa; font-family: 'Segoe UI', sans-serif; }

        /* Sidebar */
        #sidebar {
            width: var(--sidebar-width); background: var(--sidebar-bg);
            color: var(--sidebar-text); display: flex; flex-direction: column;
            position: fixed; top: 0; left: 0; height: 100vh; z-index: 100;
            transition: width .2s ease; overflow: hidden;
        }
        #sidebar.collapsed { width: var(--sidebar-collapsed-width); }

        .sidebar-toggle-row {
            display: flex; justify-content: flex-end;
            padding: .5rem .75rem .25rem;
        }
        #btn-sidebar-toggle {
            background: none; border: none; color: #adb5bd; cursor: pointer;
            padding: 0; font-size: .85rem; line-height: 1;
        }
        #btn-sidebar-toggle:hover { color: #fff; }
        #sidebar .brand {
            padding: .5rem 1.5rem .75rem; font-size: 1rem; font-weight: 700;
            color: #fff; border-bottom: 1px solid #2d3139; letter-spacing: .5px;
            white-space: nowrap; min-width: var(--sidebar-width);
        }
        #sidebar .brand span { color: var(--accent); }

        #sidebar nav { flex: 1; padding: .75rem 0; overflow: hidden; }
        #sidebar nav a {
            display: flex; align-items: center; gap: .75rem;
            padding: .6rem 1.5rem; color: var(--sidebar-text);
            text-decoration: none; font-size: .875rem;
            white-space: nowrap; min-width: var(--sidebar-width);
        }
        #sidebar nav a.active {
            color: #fff; background: #0d6efd22;
            border-left: 3px solid var(--accent);
        }
        #sidebar nav a i { width: 16px; text-align: center; flex-shrink: 0; }
        #sidebar .sidebar-footer {
            padding: 1rem 1.5rem; font-size: .75rem;
            color: #555; border-top: 1px solid #2d3139;
            white-space: nowrap; min-width: var(--sidebar-width);
        }

        /* Main content */
        #main { margin-left: var(--sidebar-width); flex: 1; display: flex; flex-direction: column; transition: margin-left .2s ease; }
        #main.sidebar-collapsed { margin-left: var(--sidebar-collapsed-width); }
        #topbar {
            background: #fff; border-bottom: 1px solid #dee2e6;
            padding: .75rem 1.5rem; display: flex; align-items: center;
            justify-content: space-between; position: sticky; top: 0; z-index: 50;
        }
        #topbar h1 { font-size: 1.1rem; font-weight: 600; margin: 0; color: #212529; }
        #content { padding: 1.5rem; flex: 1; color: #212529; }

        /* Darker content text */
        #content .text-muted { color: #555 !important; }
        #content small.text-muted { color: #666 !important; }
        .table-card .table tbody td { color: #212529; }
        .table-card .table thead th { color: #444; }

        /* Cards */
        .stat-card { border: none; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
        .stat-card .card-body { padding: 1.25rem; }
        .stat-number { font-size: 2rem; font-weight: 700; line-height: 1; }
        .stat-label  { font-size: .8rem; color: #6c757d; margin-top: .25rem; }

        /* Tables */
        .table-card { background: #fff; border-radius: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.08); overflow: hidden; }
        .table-card .table { margin: 0; font-size: .875rem; }
        .table-card .table thead th {
            background: #f8f9fa; border-bottom: 2px solid #dee2e6;
            font-weight: 600; font-size: .8rem; text-transform: uppercase;
            letter-spacing: .5px; color: #6c757d;
        }
        .table-card .table tbody tr:hover { background: #f0f4ff; cursor: pointer; }

        /* Rating badges */
        .badge-rating { font-size: .75rem; padding: .3em .65em; border-radius: 20px; }

        /* Loading spinner overlay */
        #ajax-spinner {
            display: none; position: fixed; top: 50%; left: 50%;
            transform: translate(-50%,-50%); z-index: 9999;
        }
        #ajax-spinner .spinner-border { width: 3rem; height: 3rem; }

        /* Pagination */
        .pagination { margin: 0; }
        .pagination .page-link { font-size: .875rem; }

        /* Status toggle button (shared across pages) */
        .status-btn {
            width: 20px; height: 20px; border-radius: 50%;
            border: 2px solid #adb5bd; background: #adb5bd;
            cursor: pointer; font-size: 11px; line-height: 1;
            color: #fff; padding: 0; transition: all .15s;
        }
        .status-btn:hover { border-color: #868e96; background: #868e96; }
        .status-btn.rated { border-color: #28a745; background: #28a745; color: #fff; }

        /* Rating color picker (shared across pages) */
        .rating-picker { position: relative; display: inline-block; }
        .rating-picker-btn {
            width: 36px; height: 26px;
            border: 2px solid #ced4da; border-radius: 3px;
            cursor: pointer; background: #e9ecef; padding: 0;
        }
        .rating-picker-btn.has-color { border-color: rgba(0,0,0,.3); }
        .rating-picker-panel {
            display: none; position: absolute;
            top: calc(100% + 4px); left: 0; z-index: 1050;
            background: #fff; border: 1px solid #ced4da;
            border-radius: 4px; padding: 5px;
            box-shadow: 0 2px 8px rgba(0,0,0,.18);
            flex-direction: row; gap: 5px; align-items: center;
        }
        .rating-picker-panel.open { display: flex; }
        .rating-swatch {
            width: 24px; height: 24px; border-radius: 3px;
            cursor: pointer; border: 2px solid rgba(0,0,0,.15);
            flex-shrink: 0; transition: transform .1s, border-color .1s;
        }
        .rating-swatch:hover { border-color: rgba(0,0,0,.55); transform: scale(1.15); }
        .rating-swatch.active { border-color: #000; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Sidebar -->
<aside id="sidebar">
    <div class="sidebar-toggle-row">
        <button id="btn-sidebar-toggle" title="Toggle sidebar"><i class="fas fa-chevron-left"></i></button>
    </div>
    <div class="brand">
        <span>📧 Email<span>Tracker</span></span>
    </div>
    <nav>
        <a asp-controller="Home"    asp-action="Index"  class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Home"    ? "active" : "")">
            <i class="fas fa-tachometer-alt"></i> Dashboard
        </a>
        <a asp-controller="Run"     asp-action="Index"  class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Run"     ? "active" : "")">
            <i class="fas fa-layer-group"></i> Runs
        </a>
        <a asp-controller="Message" asp-action="Index"
           class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Message" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
            <i class="fas fa-envelope"></i> Messages
        </a>
        <a asp-controller="Message" asp-action="Grouped"
           class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Grouped" ? "active" : "")">
            <i class="fas fa-layer-group"></i> CEA Groups
        </a>
        <a asp-controller="Message" asp-action="CeaReports"
           class="@(ViewContext.RouteData.Values["action"]?.ToString() == "CeaReports" ? "active" : "")">
            <i class="fas fa-file-alt"></i> CEA Reports
        </a>
        <a asp-controller="Message" asp-action="Browse"
           class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Browse" && ViewContext.RouteData.Values["controller"]?.ToString() == "Message" ? "active" : "")">
            <i class="fas fa-address-card"></i> Msg Browse
        </a>
        <a asp-controller="Sender"  asp-action="Index"  class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Sender" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
            <i class="fas fa-users"></i> Senders
        </a>
        <a asp-controller="Sender"  asp-action="Browse" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Browse" ? "active" : "")">
            <i class="fas fa-address-card"></i> Browse Senders
        </a>
        <a asp-controller="Sender"  asp-action="Index"  class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Summary" ? "active" : "")"
           title="Pick a sender from the list to view their summary">
            <i class="fas fa-layer-group"></i> Sender Summary
        </a>
        <a asp-controller="Sender"  asp-action="QuickRate" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "QuickRate" ? "active" : "")">
            <i class="fas fa-star-half-alt"></i> Quick Rate
        </a>
        <hr style="border-color:#2d3139;margin:.5rem 1rem" />
        <a asp-controller="GmailIngest" asp-action="Index" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "GmailIngest" ? "active" : "")">
            <i class="fas fa-download"></i> Gmail Ingest
        </a>
    </nav>
    <div class="sidebar-footer">v1.0 · SQLite</div>
</aside>

<!-- Main -->
<div id="main">
    <header id="topbar">
        <h1>@ViewData["Title"]</h1>
        <small class="text-muted">@DateTime.Now.ToString("dddd, MMMM d, yyyy")</small>
    </header>
    <main id="content">
        @RenderBody()
    </main>
</div>

<!-- AJAX spinner -->
<div id="ajax-spinner">
    <div class="spinner-border text-primary"></div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
<script>
    // Rating color picker — open/close (shared)
    $(document).on('click', '.rating-picker-btn', function (e) {
        e.stopPropagation();
        var $panel = $(this).closest('.rating-picker').find('.rating-picker-panel');
        var wasOpen = $panel.hasClass('open');
        $('.rating-picker-panel').removeClass('open');
        if (!wasOpen) $panel.addClass('open');
    });
    $(document).on('click', function () { $('.rating-picker-panel').removeClass('open'); });

    // Status toggle — shared across all pages
    $(document).on('click', '.status-btn', function () {
        var $btn     = $(this);
        var senderId = parseInt($btn.data('sender-id'));
        var nextId   = parseInt($btn.data('next-status-id'));
        var token    = $('input[name="__RequestVerificationToken"]').val();
        $.ajax({
            url: '/Sender/SetStatus', method: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': token },
            data: JSON.stringify({ senderId: senderId, statusId: nextId }),
            success: function (res) {
                if (res.success) {
                    var nowRated = res.statusName === 'RATED';
                    $btn.toggleClass('rated', nowRated)
                        .text(nowRated ? '✓' : '○')
                        .attr('title', res.statusName)
                        .data('next-status-id', nowRated ? 1 : 2);
                }
            }
        });
    });

    // Sidebar collapse
    (function () {
        var collapsed = localStorage.getItem('sidebar-collapsed') === '1';
        function apply(c) {
            $('#sidebar').toggleClass('collapsed', c);
            $('#main').toggleClass('sidebar-collapsed', c);
            $('#btn-sidebar-toggle i')
                .toggleClass('fa-chevron-left', !c)
                .toggleClass('fa-chevron-right', c);
        }
        apply(collapsed);
        $('#btn-sidebar-toggle').on('click', function () {
            collapsed = !collapsed;
            localStorage.setItem('sidebar-collapsed', collapsed ? '1' : '0');
            apply(collapsed);
        });
    })();

    // Global AJAX helpers
    $(document).ajaxStart(() => $('#ajax-spinner').show())
               .ajaxStop(()  => $('#ajax-spinner').hide());

    function loadPartial(url, targetSelector) {
        $.get(url, function(html) {
            $(targetSelector).html(html);
        });
    }
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
